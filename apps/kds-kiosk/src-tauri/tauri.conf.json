{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HummyTummy KDS",
  "version": "0.1.0",
  "identifier": "com.hummytummy.kds-kiosk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HummyTummy KDS",
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "fullscreen": true,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": "default-src 'self' https:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "nsis", "msi", "app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
