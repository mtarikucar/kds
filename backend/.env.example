# Application
NODE_ENV=development
PORT=3000
APP_NAME=HummyTummy

# Logging (Winston)
LOG_LEVEL=info
# Levels: error, warn, info, http, verbose, debug, silly
LOG_TO_FILE=false
# Set to true in production to enable file logging with daily rotation

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_pos?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production-32chars
# Access token lifetime. Short by design — refresh tokens rotate server-side.
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# bcrypt work factor for password hashing (10-15; 12 is the 2026 baseline).
BCRYPT_COST=12

# Separate JWT realm for platform SuperAdmin. Must be at least 32 chars
# and MUST differ from JWT_SECRET / JWT_REFRESH_SECRET. Boot fails if
# either is missing or too short.
SUPERADMIN_JWT_SECRET=change-me-32-chars-minimum-superadmin-jwt-secret
SUPERADMIN_JWT_REFRESH_SECRET=change-me-32-chars-minimum-superadmin-refresh-secret

# Master key for envelope-encrypting at-rest secrets (delivery-platform
# API credentials, access tokens). Must be at least 32 chars; changing
# it will invalidate every encrypted value already in the DB.
ENCRYPTION_MASTER_KEY=change-me-32-chars-minimum-at-rest-encryption-key

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID (Web application)
# 2. Add authorized JavaScript origins: http://localhost:5173, https://yourdomain.com
# 3. Add authorized redirect URIs if using server-side flow
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Apple Sign-In
# Get credentials from: https://developer.apple.com/account/resources/identifiers/list/serviceId
# 1. Create App ID with Sign In with Apple capability
# 2. Create Services ID for web authentication
# 3. Configure domains and return URLs
# 4. Create Sign In with Apple key (.p8 file)
APPLE_CLIENT_ID=com.yourcompany.yourapp.service
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
# Convert .p8 key to single line: awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' AuthKey.p8
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----"

# CORS
CORS_ORIGIN=http://localhost:5173
# Frontend URL for QR code generation and redirects
FRONTEND_URL=http://localhost:5173

# Rate Limiting (Throttler)
# Tier 1: Requests per second
THROTTLE_TTL_SHORT=1000
THROTTLE_LIMIT_SHORT=10
# Tier 2: Requests per 10 seconds
THROTTLE_TTL_MEDIUM=10000
THROTTLE_LIMIT_MEDIUM=50
# Tier 3: Requests per minute
THROTTLE_TTL_LONG=60000
THROTTLE_LIMIT_LONG=100

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# PayTR Payment Provider (Turkey)
# Get your credentials from: https://www.paytr.com/magaza/merchant-panel
PAYTR_MERCHANT_ID=your_merchant_id
PAYTR_MERCHANT_KEY=your_merchant_key
PAYTR_MERCHANT_SALT=your_merchant_salt
PAYTR_BASE_URL=https://www.paytr.com
# Set to "true" for sandbox/test mode
PAYTR_TEST_MODE=true

# Backend URL (for PayTR webhook callback)
BACKEND_URL=http://localhost:3000

# Subscription Settings
DEFAULT_TRIAL_DAYS=14
TRIAL_REMINDER_DAYS=3

# Desktop App Release API Key
# Used by GitHub Actions for automated desktop app releases
# Generate a secure random key: openssl rand -hex 32
DESKTOP_RELEASE_API_KEY=your-secure-random-api-key-here

# Email Configuration (SMTP)
# Using GoDaddy SMTP server (Titan Email via GoDaddy)
# Authenticate with admin@, send from noreply@, receive at contact@
EMAIL_HOST=smtpout.secureserver.net
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=admin@hummytummy.com
EMAIL_PASSWORD=your-godaddy-email-password-here
EMAIL_FROM=noreply@hummytummy.com
ADMIN_EMAIL=contact@hummytummy.com

# Sentry Error Tracking
# Get your DSN from: https://sentry.io/settings/projects/
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Enable performance monitoring (0.0 - 1.0, 0.1 = 10% of transactions)
SENTRY_TRACES_SAMPLE_RATE=0.1
# Enable profiling (0.0 - 1.0)
SENTRY_PROFILES_SAMPLE_RATE=0.1

# SMS Provider Configuration
# Set SMS_PROVIDER to force a provider: "netgsm" or "twilio"
# Leave empty to auto-detect (tries NetGSM first, then Twilio)
# Leave all credentials empty to use mock SMS (development mode)
SMS_PROVIDER=

# NetGSM (recommended for Turkey - ~0.065 TL per SMS)
# Get credentials from: https://www.netgsm.com.tr/
NETGSM_USERCODE=
NETGSM_PASSWORD=
NETGSM_MSGHEADER=

# Twilio (international - ~$0.09 per SMS to Turkey)
# Get credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── kds-marketing service (Phase-5 split) ──────────────────────────────
# The marketing bounded context runs as the separate kds-marketing service.
# (MARKETING_JWT_* / MARKETING_INGEST_TOKEN moved there with it.)
#
# Base URL of the kds-marketing service, e.g. http://localhost:3100
# (the kds-marketing compose publishes its backend on host port 3100).
# When unset: referral codes resolve to null (payments still succeed, just
# without marketing attribution) and payment.succeeded.v1 events are NOT
# relayed to the marketing service; marketing-bound outbox rows are parked
# (kept pending) until it is configured.
MARKETING_SERVICE_URL=

# Shared secret for service-to-service calls in BOTH directions
# (x-internal-token header on /api/internal/* endpoints of either service).
# Must match the kds-marketing deployment. Generate: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=


# ── Camera / computer-vision analytics (INERT by default) ──────────────────
# The camera suite — camera management, occupancy heatmaps, traffic-flow +
# congestion, edge-device ingest, calibration — ships DORMANT until on-site
# cameras are provisioned. While false: the /api/analytics camera+heatmap+
# traffic+mock-data endpoints 404, the edge-device WebSocket refuses
# connections, and the retention sweep no-ops. Non-camera analytics (table
# utilization, sales insights) stay live regardless. Set to true (backend)
# AND rebuild the frontend with CAMERA_ANALYTICS_ENABLED=true to reactivate.
CAMERA_ANALYTICS_ENABLED=false

# ── Delivery-platform order moderation ─────────────────────────────────
# Minutes a marketplace order (Yemeksepeti/Getir/Trendyol/Migros) may sit in
# PENDING_APPROVAL before DeliveryApprovalTimeoutScheduler auto-rejects it:
# the platform is told to cancel, so the customer gets a fast refund instead
# of a ghost order that will never be cooked. Read per-tick (a change takes
# effect without a restart). Default 15. Set to 0 to disable auto-reject
# entirely (manual moderation only).
DELIVERY_APPROVAL_TIMEOUT_MINUTES=15
