// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// TENANT & USER MANAGEMENT
// ========================================

model Tenant {
  id        String  @id @default(uuid())
  name      String
  subdomain String? @unique
  status    String  @default("ACTIVE") // ACTIVE, SUSPENDED, DELETED

  // Subscription details
  currentPlanId    String?
  // Legacy "ever used any trial" flag. Kept for backward-compat with
  // reporting queries and the marketing-leads converter. Per-plan
  // trial eligibility lives in `usedTrialPlanIds` below.
  trialUsed        Boolean   @default(false)
  // Plans the tenant has already trialed. Per-plan trial model lets a
  // tenant try BASIC, decline, then later try PRO. Eligibility check:
  //   !usedTrialPlanIds.includes(targetPlanId)
  usedTrialPlanIds String[]  @default([])
  trialStartedAt   DateTime?
  trialEndsAt      DateTime?

  // Turkish tax identifier (Vergi No for B2B / TC Kimlik for B2C). Required
  // on KDV-compliant invoices for Turkish tenants.
  taxId String?

  // Currency settings
  currency String @default("TRY") // USD, EUR, GBP, TRY, CAD, AUD

  // Restaurant location (for QR menu geolocation validation)
  latitude       Float? // Restaurant latitude coordinate
  longitude      Float? // Restaurant longitude coordinate
  locationRadius Int    @default(100) // Maximum allowed distance in meters (default 100m)

  // Report settings
  closingTime        String?  @default("23:00") // Store closing time in HH:mm format
  timezone           String   @default("UTC") // Timezone for the tenant
  reportEmailEnabled Boolean  @default(false) // Enable automated email reports
  reportEmails       String[] @default([]) // Array of email addresses to send reports

  // WiFi settings
  wifiSsid     String? // WiFi network name
  wifiPassword String? // WiFi password

  // Social media links
  socialInstagram String? // Instagram username or URL
  socialFacebook  String? // Facebook page URL
  socialTwitter   String? // Twitter/X username or URL
  socialTiktok    String? // TikTok username or URL
  socialYoutube   String? // YouTube channel URL
  socialWhatsapp  String? // WhatsApp business number

  // Feature & limit overrides (SuperAdmin can override plan defaults per tenant)
  featureOverrides Json? // { "advancedReports": true, "reservationSystem": false }
  limitOverrides   Json? // { "maxUsers": 50, "maxTables": 100 }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  users               User[]
  categories          Category[]
  products            Product[]
  productImages       ProductImage[]
  modifierGroups      ModifierGroup[]
  modifiers           Modifier[]
  tables              Table[]
  orders              Order[]
  stockMovements      StockMovement[]
  subscriptions       Subscription[]
  qrMenuSettings      QrMenuSettings?
  posSettings         PosSettings?
  reservationSettings ReservationSettings?
  smsSettings         SmsSettings?
  accountingSettings  AccountingSettings?
  salesInvoices       SalesInvoice[]
  reservations        Reservation[]
  integrationSettings IntegrationSettings[]
  apiKeys             ApiKey[]
  customers           Customer[]
  notifications       Notification[]
  zReports            ZReport[]
  currentPlan         SubscriptionPlan?     @relation("CurrentPlan", fields: [currentPlanId], references: [id], onDelete: SetNull)

  // Analytics relations
  cameras            Camera[]
  occupancyRecords   OccupancyRecord[]
  trafficFlowRecords TrafficFlowRecord[]
  tableAnalytics     TableAnalytics[]
  analyticsInsights  AnalyticsInsight[]
  heatmapCache       AnalyticsHeatmapCache[]
  edgeDevices        EdgeDevice[]

  // Delivery platform relations
  deliveryPlatformConfigs DeliveryPlatformConfig[]
  deliveryPlatformLogs    DeliveryPlatformLog[]
  menuItemMappings        MenuItemMapping[]

  // Stock management relations
  stockItemCategories StockItemCategory[]
  stockItems          StockItem[]
  stockBatches        StockBatch[]
  recipes             Recipe[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  ingredientMovements IngredientMovement[]
  wasteLogs           WasteLog[]
  stockCounts         StockCount[]
  stockSettings       StockSettings?

  // Personnel management relations
  attendances          Attendance[]
  shiftTemplates       ShiftTemplate[]
  shiftAssignments     ShiftAssignment[]
  shiftSwapRequests    ShiftSwapRequest[]
  marketingCommissions Commission[]       @relation("MarketingCommissions")
  convertedLead        Lead?              @relation("ConvertedTenant")

  // Previously-orphaned relations (migration 20260420180000 adds the FKs).
  // Listed here so Prisma keeps the TS-side relation graph in sync.
  payments            Payment[]
  orderItemPayments   OrderItemPayment[]
  pendingSelfPayments PendingSelfPayment[]
  customerSessions    CustomerSession[]
  phoneVerifications  PhoneVerification[]
  waiterRequests      WaiterRequest[]
  billRequests        BillRequest[]
  cashDrawerMovements CashDrawerMovement[]
  userActivities      UserActivity[]
  loyaltyTransactions LoyaltyTransaction[]

  // v2.8.92: explicit FK + cascade for the entitlement engine. Pre-v2.8.92
  // FeatureEntitlement.tenantId was a free-form String — no FK, no cascade.
  // Deleting a tenant left orphan rows in feature_entitlements, and an
  // accidental tenantId typo at write-time would silently succeed. The
  // cascade aligns with how every other tenant-scoped table is wired.
  featureEntitlements FeatureEntitlement[]

  // v2.8.93 — Branch + Device picked up the missing tenant FK + cascade.
  // Inverse relations declared here so Prisma keeps the TS-side graph
  // consistent. Pre-fix both tables were orphan-prone.
  branches            Branch[]
  devices             Device[]

  @@index([currentPlanId])
  @@index([status])
  @@map("tenants")
}

/**
 * Per-session refresh tokens. Only the sha256 hash is stored so a DB leak
 * does not yield usable tokens. Each successful refresh rotates the token
 * (marks the old one revoked, issues a new one). Logout / admin suspend
 * sets revokedAt on all of a user's tokens.
 */
model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

/**
 * Subdomains released by deleted/suspended tenants or settings changes
 * are parked here for a quarantine window to prevent subdomain takeover
 * (a new tenant picking up a subdomain still referenced by printed QR
 * codes, outbound emails, cached links).
 */
model ReservedSubdomain {
  id             String   @id @default(uuid())
  subdomain      String   @unique
  reason         String // 'tenant_deleted' | 'tenant_suspended' | 'subdomain_changed'
  reservedAt     DateTime @default(now())
  availableAfter DateTime

  @@index([availableAfter])
  @@map("reserved_subdomains")
}

model User {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String
  lastName  String
  role      String // ADMIN, MANAGER, WAITER, KITCHEN, COURIER
  status    String @default("ACTIVE") // ACTIVE, INACTIVE, PENDING_APPROVAL

  // User approval (for non-ADMIN users joining existing restaurants)
  approvedAt    DateTime?
  approvedById  String?
  approvedBy    User?     @relation("UserApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedUsers User[]    @relation("UserApprover")

  // Reactivation audit (when a soft-deleted user is brought back)
  reactivatedAt    DateTime?
  reactivatedById  String?
  reactivatedBy    User?     @relation("UserReactivator", fields: [reactivatedById], references: [id], onDelete: SetNull)
  reactivatedUsers User[]    @relation("UserReactivator")

  // Email verification (code-based, hashed at rest)
  emailVerified                Boolean   @default(false)
  emailVerificationCodeHash    String?
  emailVerificationCodeExpires DateTime?

  // Password reset (token hashed at rest)
  resetTokenHash   String?   @unique
  resetTokenExpiry DateTime?

  // Session revocation: JWT payload carries `ver`; incrementing this field
  // invalidates every access token issued before the bump. Used on password
  // reset / suspicious-login / admin lockout.
  tokenVersion Int @default(0)

  // Profile
  avatar    String?
  phone     String?
  lastLogin DateTime?

  // Social Authentication
  googleId     String? @unique
  appleId      String? @unique
  authProvider String  @default("local") // local, google, apple

  // Onboarding data (persisted for cross-device sync)
  onboardingData Json? // { hasSeenWelcome, tourProgress, skipAllTours }

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  refreshTokens              RefreshToken[]
  orders                     Order[]
  approvedOrders             Order[]                @relation("ApprovedOrders")
  acknowledgedWaiterRequests WaiterRequest[]        @relation("AcknowledgedWaiterRequests")
  acknowledgedBillRequests   BillRequest[]          @relation("AcknowledgedBillRequests")
  stockMovements             StockMovement[]
  notifications              Notification[]
  readNotifications          UserNotificationRead[]
  zReports                   ZReport[]
  cashDrawerMovements        CashDrawerMovement[]

  // Personnel management relations
  attendances          Attendance[]
  shiftAssignments     ShiftAssignment[]
  swapRequestsMade     ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsReceived ShiftSwapRequest[] @relation("SwapTarget")
  swapRequestsApproved ShiftSwapRequest[] @relation("SwapApprover")

  // Legal consents — every accepted version of KVKK / Mesafeli Satış
  // / İade / Terms is recorded for audit. Cascade-delete with the user
  // because a removed user can't be asked to re-accept anything.
  consents Consent[]

  @@index([tenantId])
  @@index([email])
  @@index([approvedById])
  @@map("users")
}

// ========================================
// MENU MANAGEMENT
// ========================================

model Category {
  id           String  @id @default(uuid())
  name         String
  description  String?
  displayOrder Int     @default(0)
  isActive     Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products Product[]

  @@index([tenantId])
  @@map("categories")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  image       String? // Legacy field, kept for backwards compatibility

  isAvailable  Boolean @default(true)
  stockTracked Boolean @default(false)
  currentStock Int     @default(0)
  displayOrder Int     @default(0)
  taxRate      Int     @default(10) // KDV rate: 0, 1, 10, 20

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  productImages    ProductToImage[] // Many-to-many through junction table
  orderItems       OrderItem[]
  stockMovements   StockMovement[]
  modifierGroups   ProductModifierGroup[] // Many-to-many for modifiers
  menuItemMappings MenuItemMapping[]
  recipe           Recipe? // Ingredient-level recipe for stock deduction

  @@index([tenantId])
  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id       String @id @default(uuid())
  url      String // File path or URL
  filename String // Original filename
  size     Int // File size in bytes
  mimeType String // image/jpeg, image/png, image/webp

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  // Relations
  products ProductToImage[] // Many-to-many through junction table

  @@index([tenantId])
  @@map("product_images")
}

// Junction table for many-to-many relationship between Product and ProductImage
model ProductToImage {
  id    String @id @default(uuid())
  order Int    @default(0) // Display order (0 = primary image)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  imageId String
  image   ProductImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, imageId]) // Prevent duplicate links
  @@index([productId, order])
  @@index([imageId])
  @@map("product_to_images")
}

// ========================================
// PRODUCT MODIFIER SYSTEM
// ========================================

model ModifierGroup {
  id            String  @id @default(uuid())
  name          String // Internal name (e.g., "sauces")
  displayName   String // Display name (e.g., "Soslar", "Sauces")
  description   String?
  selectionType String  @default("SINGLE") // SINGLE or MULTIPLE
  minSelections Int     @default(0) // Minimum number of selections required
  maxSelections Int? // Maximum number of selections allowed (null = unlimited)
  isRequired    Boolean @default(false)
  displayOrder  Int     @default(0)
  isActive      Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  modifiers       Modifier[]
  productMappings ProductModifierGroup[]

  @@index([tenantId])
  @@index([isActive])
  @@map("modifier_groups")
}

model Modifier {
  id              String  @id @default(uuid())
  name            String // Internal name (e.g., "ranch_sauce")
  displayName     String // Display name (e.g., "Ranch Sos", "Ranch Sauce")
  description     String?
  priceAdjustment Decimal @default(0) @db.Decimal(10, 2) // Price change (can be positive or negative)
  isAvailable     Boolean @default(true)
  displayOrder    Int     @default(0)

  groupId String
  group   ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orderItemModifiers OrderItemModifier[]

  @@index([groupId])
  @@index([tenantId])
  @@index([isAvailable])
  @@map("modifiers")
}

// Junction table for many-to-many relationship between Product and ModifierGroup
model ProductModifierGroup {
  id           String @id @default(uuid())
  displayOrder Int    @default(0)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  groupId String
  group   ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, groupId])
  @@index([productId])
  @@index([groupId])
  @@map("product_modifier_groups")
}

// ========================================
// TABLE MANAGEMENT
// ========================================

model Table {
  id       String  @id @default(uuid())
  number   String
  capacity Int
  section  String?
  status   String  @default("AVAILABLE") // AVAILABLE, OCCUPIED, RESERVED

  // When status=RESERVED was set by the reservation-scheduler (auto-hold
  // ~30 min before a CONFIRMED reservation begins), this points at the
  // reservation that owns the hold. The release tick uses this to
  // distinguish auto-holds from manually-RESERVED tables (which have
  // reservationHoldId=null and must never be auto-cleared).
  // SetNull on delete so deleting a reservation doesn't blow up the table row.
  reservationHoldId String?
  reservationHold   Reservation? @relation("TableReservationHold", fields: [reservationHoldId], references: [id], onDelete: SetNull)

  // Table grouping (merge/split)
  groupId String? // Shared UUID for merged tables; null = standalone

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // HummyTummy Phase 3: branch the table physically belongs to.
  // Nullable — pre-existing tables predate the Branch model and stay
  // tenant-scoped. New tables created via the branches UI carry a real
  // branchId, and OrdersService.create copies it onto the order.
  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  orders         Order[]
  waiterRequests WaiterRequest[]
  billRequests   BillRequest[]

  // Analytics relations
  occupancyRecords OccupancyRecord[]
  tableAnalytics   TableAnalytics[]
  // Reservations assigned to this table (covers the lifetime of every
  // booking; the reservationHold field above is the *currently active*
  // auto-hold pointer, while this list is the full backlog/history).
  reservations     Reservation[]     @relation("ReservationAssignedTable")

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, groupId])
  @@index([tenantId, branchId])
  @@map("tables")
}

// ========================================
// ORDER MANAGEMENT
// ========================================

model Order {
  id          String @id @default(uuid())
  orderNumber String
  type        String // DINE_IN, TAKEAWAY, DELIVERY, COUNTER
  status      String @default("PENDING") // PENDING_APPROVAL, PENDING, PREPARING, READY, SERVED, PAID, CANCELLED

  totalAmount Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  finalAmount Decimal @db.Decimal(10, 2)
  taxAmount   Decimal @default(0) @db.Decimal(10, 2)

  notes        String?
  customerName String?

  // Delivery platform fields
  source          String? // YEMEKSEPETI, GETIR, TRENDYOL, MIGROS (NULL = internal/POS order)
  externalOrderId String? // Platform's order ID/token for status sync
  externalData    Json? // Raw platform payload for audit trail

  // Captured at order-create time so the kitchen ticket is reprintable
  // and survives later edits to items/modifiers. Owned by ReceiptSnapshotBuilder.
  kitchenTicketSnapshot Json?

  // Client-generated UUID for double-tap / retry deduplication. The
  // partial unique index on (tenantId, idempotencyKey) is added by the
  // companion migration — Prisma's @@unique would also dedupe NULLs
  // (Postgres treats them as distinct), so the partial index is the
  // mechanism that actually enforces the guarantee for keyed requests.
  idempotencyKey String?

  // Customer ordering fields
  sessionId        String? // UUID for customer session tracking
  customerPhone    String? // Optional customer phone
  requiresApproval Boolean   @default(false) // If true, waiter must approve before going to kitchen
  approvedAt       DateTime? // When the order was approved

  // Idempotency flag for recipe/stock deduction. Prevents duplicate
  // deductions when deductOnStatus is tweaked mid-lifecycle or when
  // multiple status-change hooks race.
  stockDeducted Boolean @default(false)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  customerId String?
  customer   Customer? @relation("CustomerOrders", fields: [customerId], references: [id], onDelete: SetNull)

  userId String? // Nullable for customer orders
  user   User?   @relation(fields: [userId], references: [id], onDelete: Restrict)

  approvedById String? // Staff who approved the order
  approvedBy   User?   @relation("ApprovedOrders", fields: [approvedById], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // HummyTummy Phase 3: branch-scoping. Nullable because orders that
  // pre-date the Branch model don't have one; new orders pick the branch
  // from the table or from the cashier's session. Reports filter on this
  // column when the caller passes branchId — null-branch orders simply
  // aren't returned by branch-scoped queries, which is the correct
  // behavior (they're shown in tenant-wide reports).
  branchId String?
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  paidAt      DateTime?
  preparingAt DateTime?
  readyAt     DateTime?
  cancelledAt DateTime?

  // Relations
  orderItems    OrderItem[]
  payments      Payment[]
  // Pluralized: progressive flow generates one SalesInvoice per
  // Payment; the legacy single-payment flow still produces one
  // invoice per order. Both shapes are valid in this list.
  salesInvoices SalesInvoice[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([userId])
  @@index([tableId])
  @@index([tenantId, branchId, createdAt])
  @@index([customerId])
  @@index([status])
  @@index([sessionId])
  @@index([approvedById])
  @@index([source])
  @@index([externalOrderId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, tableId, status])
  // Reports / z-report hot path: WHERE tenantId AND status='PAID' AND
  // paidAt BETWEEN ?. With the prior [tenantId, status] + [tenantId, createdAt]
  // pair, Postgres had to filter by paidAt in-memory on every report query.
  @@index([tenantId, status, paidAt])
  // Cancelled-order section of the z-report keys on cancelledAt.
  @@index([tenantId, status, cancelledAt])
  @@map("orders")
}

model OrderItem {
  id            String  @id @default(uuid())
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  subtotal      Decimal @db.Decimal(10, 2)
  modifierTotal Decimal @default(0) @db.Decimal(10, 2) // Total cost of modifiers
  taxRate       Int     @default(10)
  taxAmount     Decimal @default(0) @db.Decimal(10, 2)
  notes         String?
  status        String  @default("PENDING") // PENDING, PREPARING, READY

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  modifiers         OrderItemModifier[]
  orderItemPayments OrderItemPayment[]

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

// Modifiers selected for a specific order item
model OrderItemModifier {
  id              String  @id @default(uuid())
  quantity        Int     @default(1) // How many of this modifier (e.g., 2x extra cheese)
  priceAdjustment Decimal @db.Decimal(10, 2) // Price at the time of order

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  modifierId String
  modifier   Modifier @relation(fields: [modifierId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([orderItemId])
  @@index([modifierId])
  @@map("order_item_modifiers")
}

// ========================================
// PAYMENT MANAGEMENT
// ========================================

model Payment {
  id     String  @id @default(uuid())
  amount Decimal @db.Decimal(10, 2)
  method String // CASH, CARD, DIGITAL
  status String  @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED

  transactionId  String?
  idempotencyKey String?
  notes          String?

  // Captured at payment-create time so receipts remain reprintable even if
  // the printer was offline, and survive future product/menu/tenant edits.
  // Shape is owned by ReceiptSnapshotBuilder; see services/receipt-snapshot.builder.ts.
  // Versioned via the `version` field inside the JSON.
  receiptSnapshot Json?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  orderId  String
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // Customer this specific Payment belongs to. Set by progressive
  // payments (each diner can hand the waiter their own phone for
  // loyalty) and by the legacy single-payment flow (customer of
  // record for the whole bill). NULL means the payment was anonymous.
  // The order.customerId remains "primary customer on the bill" for
  // legacy display; this column lets per-customer stats stay clean
  // when a single order has multiple paying customers.
  customerId String?
  customer   Customer? @relation("CustomerPayments", fields: [customerId], references: [id], onDelete: SetNull)

  createdAt DateTime  @default(now())
  paidAt    DateTime?

  // Per-item allocations for progressive ("Dutch-style") payments.
  // Populated only by payByItems(); empty for whole-bill and split-bill
  // payments. See OrderItemPayment for the integrity rules.
  orderItemPayments OrderItemPayment[]

  // Per-payment invoice(s) — Turkish e-fatura per-customer. Each
  // progressive payment can have at most one SalesInvoice (enforced
  // by the partial unique index `sales_invoices_paymentId_notnull_key`
  // in migration 20260513140000). Modelled as a 1-to-many here purely
  // because Prisma's 1-to-1 defining-side validator wants @unique on
  // a nullable column, which would inflate the index footprint.
  // Consumers should expect at most one row.
  salesInvoices SalesInvoice[]

  // NOTE: @@unique([orderId, idempotencyKey]) does NOT dedupe null keys in
  // Postgres (multiple NULLs are considered distinct). Migration
  // 20260420180000 adds a partial unique index
  //   CREATE UNIQUE INDEX ... ON payments (order_id, idempotency_key)
  //     WHERE idempotency_key IS NOT NULL;
  // so the idempotency guarantee actually holds for keyed requests.
  @@index([tenantId])
  @@index([orderId])
  @@index([status])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("payments")
}

// Links a Payment to the specific OrderItem units it settled. Enables
// per-customer "I paid for what I ate" flows where the same order is
// closed across multiple payments over time. Quantity-level granularity
// (one row per N-units paid, not one row per OrderItem) supports paying
// 1 of 2 cocktails from a single OrderItem with quantity=2.
//
// Integrity (enforced at the service layer inside the payment tx):
//   sum(quantity) WHERE orderItemId = X AND payment.status = COMPLETED
//     <= orderItem.quantity
//
// Refund: when a Payment flips to REFUNDED, the related rows are
// `deleteMany`'d in the same tx so the units become payable again.
// (Payment is not deleted; the audit row stays.)
model OrderItemPayment {
  id String @id @default(uuid())

  paymentId String
  // RESTRICT: Payment is never hard-deleted (refund flips to REFUNDED).
  // The authorized free-the-units path is the explicit deleteMany in
  // PaymentsService.updateStatus REFUNDED branch; cascade would silently
  // nuke audit if a future hard-delete were ever added.
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Restrict)

  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Restrict)

  quantity Int

  // Snapshot of this allocation's contribution to Payment.amount. Stored,
  // not derived, so refund accounting and audits stay stable.
  amount Decimal @db.Decimal(10, 2)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([orderItemId])
  @@index([tenantId])
  // Hot read path for "which items on this order are paid?" — service
  // aggregates by orderItemId, then joins to payment.status.
  @@index([orderItemId, paymentId])
  @@map("order_item_payments")
}

// Self-pay (QR-menu customer paying their own table) intent record.
// Persisted before the PayTR token request; the webhook reads this
// row to know which OrderItem units to settle once the customer
// finishes 3DS on PayTR's hosted page. merchantOid prefix "SP"
// distinguishes self-pay from subscription "SUB" in the shared
// PaytrWebhookController dispatcher.
model PendingSelfPayment {
  id          String @id @default(uuid())
  merchantOid String @unique
  sessionId   String
  tenantId    String
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // [{ orderId, items: [{ orderItemId, quantity }] }, ...]
  itemsByOrder Json

  amount        Decimal @db.Decimal(10, 2)
  status        String  @default("PENDING") // PENDING, SUCCEEDED, FAILED, EXPIRED
  failureReason String?
  paytrToken    String?
  customerPhone String?

  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  succeededAt DateTime?

  @@index([sessionId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("pending_self_payments")
}

// ========================================
// STOCK MANAGEMENT
// ========================================

model StockMovement {
  id       String  @id @default(uuid())
  type     String // IN, OUT, ADJUSTMENT
  quantity Int
  reason   String?
  notes    String?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([productId])
  @@index([userId])
  // Hot list query: "movements for tenant X in date-range Y". The
  // single-column @@index([tenantId]) above is fine for tenant-scope
  // alone; this compound index serves the date-bounded variant
  // without a sequential scan over the tenant's history.
  @@index([tenantId, createdAt])
  @@map("stock_movements")
}

// ========================================
// SUBSCRIPTION MANAGEMENT
// ========================================

model SubscriptionPlan {
  id          String  @id @default(uuid())
  name        String  @unique // FREE, BASIC, PRO, BUSINESS
  displayName String
  description String?

  // Pricing
  monthlyPrice Decimal @db.Decimal(10, 2)
  yearlyPrice  Decimal @db.Decimal(10, 2)
  currency     String  @default("TRY")

  // Trial settings
  trialDays Int @default(0)

  // Feature limits
  maxUsers         Int @default(1)
  maxTables        Int @default(5)
  maxProducts      Int @default(50)
  maxCategories    Int @default(10)
  maxMonthlyOrders Int @default(100)

  // Feature flags
  advancedReports     Boolean @default(false)
  multiLocation       Boolean @default(false)
  customBranding      Boolean @default(false)
  apiAccess           Boolean @default(false)
  prioritySupport     Boolean @default(false)
  inventoryTracking   Boolean @default(false)
  kdsIntegration      Boolean @default(true)
  reservationSystem   Boolean @default(false)
  personnelManagement Boolean @default(false)
  deliveryIntegration Boolean @default(false)

  // Discount settings
  discountPercentage Int? // Discount percentage (e.g., 25 for 25%)
  discountLabel      String? // "New Year Special", "Holiday Offer"
  discountStartDate  DateTime? // When discount becomes active
  discountEndDate    DateTime? // When discount expires
  isDiscountActive   Boolean   @default(false)

  /// Marketing rep commission rate for SIGNUP/RENEWAL/UPSELL when this
  /// plan is involved. Decimal fraction (0.10 = 10%). Default lines up
  /// with the historical hard-coded constant so the rollout is
  /// transparent. Per-plan overrides let high-margin plans pay reps
  /// more (e.g. BUSINESS 15%) without affecting BASIC.
  commissionRate Decimal @default(0.10) @db.Decimal(5, 4)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subscriptions       Subscription[]
  currentPlanTenants  Tenant[]            @relation("CurrentPlan")
  scheduledDowngrades Subscription[]      @relation("ScheduledDowngrade")
  pendingPlanChanges  PendingPlanChange[] @relation("PendingPlanChange")
  leadOffers          LeadOffer[]

  @@map("subscription_plans")
}

model Subscription {
  id String @id @default(uuid())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  // Subscription details
  //
  // Lifecycle: PENDING → ACTIVE → (TRIALING ends) → PAST_DUE → EXPIRED
  //                          ↘ CANCELLED
  //
  // Important: PAST_DUE is a *grace period* — feature access stays
  // unlocked for 7 days after the trial ends or a renewal charge fails,
  // giving the tenant time to reach for /payments/create-intent. The
  // `past-due-subscriptions` cron then promotes PAST_DUE → EXPIRED
  // which cuts access. PlanFeatureGuard treats ACTIVE/TRIALING/PAST_DUE
  // identically as "live"; only EXPIRED/CANCELLED block access.
  status          String @default("ACTIVE") // ACTIVE, CANCELLED, EXPIRED, PAST_DUE, TRIALING, PENDING
  billingCycle    String // MONTHLY, YEARLY
  // PAYTR for Turkish tenants (self-serve via hosted iFrame + webhook);
  // EMAIL for INTERNATIONAL tenants (contact-based, superadmin-driven).
  paymentProvider String // PAYTR, EMAIL

  // Dates
  startDate          DateTime  @default(now())
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  endedAt            DateTime?

  // Trial tracking
  isTrialPeriod Boolean   @default(false)
  trialStart    DateTime?
  trialEnd      DateTime?

  // Pricing at time of subscription
  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("TRY")

  // Manual-renewal model: tenant explicitly checkouts each cycle.
  // No autoRenew flag because there's no auto-charge path. `cancelAtPeriodEnd`
  // still drives the deferred-cancellation UI.
  cancelAtPeriodEnd Boolean @default(false)

  // Cancellation tracking
  cancellationReason String?

  // Scheduled downgrade (for period end)
  scheduledDowngradePlanId       String?
  scheduledDowngradePlan         SubscriptionPlan? @relation("ScheduledDowngrade", fields: [scheduledDowngradePlanId], references: [id], onDelete: SetNull)
  scheduledDowngradeBillingCycle String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  payments           SubscriptionPayment[]
  invoices           Invoice[]
  pendingPlanChanges PendingPlanChange[]

  @@index([tenantId])
  @@index([planId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@index([scheduledDowngradePlanId])
  @@map("subscriptions")
}

model SubscriptionPayment {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  // Payment details
  amount          Decimal @db.Decimal(10, 2)
  currency        String  @default("TRY")
  status          String  @default("PENDING") // PENDING, SUCCEEDED, FAILED, REFUNDED
  paymentProvider String // PAYTR, EMAIL

  // Free-form external reference (receipt id, bank transfer id) for audit.
  externalReference String? @unique

  // PayTR merchant_oid — idempotency key tying our payment row to PayTR's
  // transaction. Generated server-side as `SUB-${tenantId}-${ts}` before the
  // token request; webhooks match on this value.
  paytrMerchantOid String? @unique
  // Short-lived token returned by PayTR get-token; persisted only for
  // debugging webhook callbacks. Not used after success.
  paytrToken       String?

  // Payment metadata
  paymentMethod String? // card, bank_transfer, etc.
  last4         String?
  cardBrand     String?

  // Error tracking
  failureCode    String?
  failureMessage String?
  retryCount     Int     @default(0)

  // Dates
  paidAt     DateTime?
  refundedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Marketing referral snapshot: the code the customer typed (or that
  // was pre-filled from a `?ref=CODE` cookie) at checkout, plus the
  // marketer it resolved to at that moment. Both nullable — most
  // payments have no referrer. Kept on the payment row (not on
  // subscription) so re-resolves are stable even if the marketer
  // later rotates their code.
  referralCode              String?
  referredByMarketingUserId String?
  referredBy                MarketingUser? @relation("ReferredByMarketer", fields: [referredByMarketingUserId], references: [id], onDelete: SetNull)

  // Relations
  invoice Invoice?

  @@index([subscriptionId])
  @@index([status])
  @@index([createdAt])
  @@index([paytrMerchantOid])
  @@index([referredByMarketingUserId])
  @@map("subscription_payments")
}

/**
 * Holds an upgrade target between intent creation and webhook confirmation.
 * When a tenant initiates a plan change that requires payment, we record
 * the target here keyed by merchantOid. The webhook reads it on success
 * and calls applyUpgrade() — keeps the intent endpoint stateless about
 * what plan was being purchased.
 */
model PendingPlanChange {
  id             String           @id @default(uuid())
  subscriptionId String
  subscription   Subscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  targetPlanId   String
  targetPlan     SubscriptionPlan @relation("PendingPlanChange", fields: [targetPlanId], references: [id], onDelete: Restrict)
  billingCycle   String // MONTHLY, YEARLY
  merchantOid    String           @unique
  expiresAt      DateTime
  createdAt      DateTime         @default(now())

  @@index([subscriptionId])
  @@map("pending_plan_changes")
}

model Invoice {
  id String @id @default(uuid())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  paymentId String?              @unique
  payment   SubscriptionPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // Invoice details
  invoiceNumber String @unique
  status        String @default("DRAFT") // DRAFT, OPEN, PAID, VOID, UNCOLLECTIBLE

  // Amounts
  subtotal Decimal @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)
  currency String  @default("TRY")

  // Billing period
  periodStart DateTime
  periodEnd   DateTime

  // Dates
  dueDate   DateTime?
  paidAt    DateTime?
  voidedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Metadata
  description String?
  notes       String?
  pdfUrl      String?

  // Snapshot of tenant taxId at issuance (Vergi No / TC Kimlik). Frozen
  // here so future taxId edits on the tenant don't retroactively rewrite
  // historical invoices.
  taxIdSnapshot String?

  @@index([subscriptionId])
  @@index([invoiceNumber])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

/**
 * Monotonic counter for invoice numbering. Updated atomically inside a
 * transaction (UPDATE ... RETURNING) so two concurrent invoice writes
 * never race on the same number.
 */
model InvoiceCounter {
  scope    String @id // e.g. "202604" (year+month)
  sequence Int    @default(0)

  @@map("invoice_counters")
}

// ========================================
// QR MENU CUSTOMIZATION
// ========================================

model QrMenuSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Design customization
  primaryColor       String  @default("#3B82F6") // Blue
  secondaryColor     String  @default("#1F2937") // Gray
  backgroundColor    String  @default("#F9FAFB") // Light gray
  fontFamily         String  @default("Inter")
  logoUrl            String?
  showRestaurantInfo Boolean @default(true)
  showPrices         Boolean @default(true)
  showDescription    Boolean @default(true)
  showImages         Boolean @default(true)

  // Layout options
  layoutStyle String @default("GRID") // GRID, LIST, COMPACT
  itemsPerRow Int    @default(2)

  // Table-specific settings
  enableTableQR  Boolean @default(true)
  tableQRMessage String  @default("Scan to view our menu")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("qr_menu_settings")
}

// ========================================
// POS SETTINGS
// ========================================

model PosSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // POS operation modes
  enableTablelessMode           Boolean @default(false) // Allow orders without table selection
  enableTwoStepCheckout         Boolean @default(false) // Separate "Create Order" and "Payment" buttons
  showProductImages             Boolean @default(true) // Show product images in POS menu
  enableCustomerOrdering        Boolean @default(true) // Allow customers to place orders from QR menu
  // Allow customers to pay their share via PayTR hosted iFrame from
  // the QR menu (self-pay flow). Opt-in: default false because it
  // requires a PayTR merchant account.
  enableCustomerSelfPay         Boolean @default(false)
  defaultMapView                String  @default("2d") // Default floor plan view: "2d" or "3d"
  requireServedForDineInPayment Boolean @default(false) // Require SERVED status for dine-in payment in two-step checkout

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("pos_settings")
}

// ========================================
// RESERVATION SETTINGS
// ========================================

model ReservationSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  isEnabled               Boolean @default(true)
  requireApproval         Boolean @default(true)
  timeSlotInterval        Int     @default(30)
  minAdvanceBooking       Int     @default(60)
  maxAdvanceDays          Int     @default(30)
  defaultDuration         Int     @default(90)
  operatingHours          Json?
  maxGuestsPerReservation Int     @default(20)
  maxReservationsPerSlot  Int?

  bannerImageUrl    String?
  bannerTitle       String?
  bannerDescription String?
  customMessage     String?

  allowCancellation    Boolean @default(true)
  cancellationDeadline Int     @default(120)

  /// How many minutes before a confirmed reservation's start time the
  /// scheduler should auto-flip an AVAILABLE table to RESERVED. Also
  /// drives the upcomingReservation annotation window on GET /tables
  /// and the POS reservation-action dialog visibility. Default 30 —
  /// the seat-on-tap UX is built for last-30-minute prep, not 2h-ahead
  /// blockade. Tenants can widen for banquets or large parties.
  holdOffsetMinutes Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("reservation_settings")
}

// ========================================
// SMS NOTIFICATION SETTINGS
// ========================================

model SmsSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  isEnabled Boolean @default(false)

  smsOnReservationCreated   Boolean @default(true)
  smsOnReservationConfirmed Boolean @default(true)
  smsOnReservationRejected  Boolean @default(true)
  smsOnReservationCancelled Boolean @default(true)

  /// Per-event email toggles. The reservation-notification abstraction
  /// prefers email when the customer supplied an email AND the matching
  /// emailOn* flag is on; otherwise it falls back to SMS. Defaults to
  /// true so the abstraction "just works" out of the box; admins can
  /// disable channels per event from the SMS/notification settings UI.
  emailOnReservationCreated   Boolean @default(true)
  emailOnReservationConfirmed Boolean @default(true)
  emailOnReservationRejected  Boolean @default(true)
  emailOnReservationCancelled Boolean @default(true)

  smsOnOrderCreated   Boolean @default(true)
  smsOnOrderApproved  Boolean @default(true)
  smsOnOrderPreparing Boolean @default(true)
  smsOnOrderReady     Boolean @default(true)
  smsOnOrderCancelled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("sms_settings")
}

// ========================================
// RESERVATION SYSTEM
// ========================================

model Reservation {
  id                String @id @default(uuid())
  reservationNumber String

  date      DateTime @db.Date
  startTime String
  endTime   String

  guestCount Int
  notes      String? @db.Text

  status String @default("PENDING") // PENDING, CONFIRMED, REJECTED, SEATED, COMPLETED, CANCELLED, NO_SHOW

  customerName  String
  /// Either customerPhone or customerEmail must be present at the
  /// application level (enforced by the @AtLeastOneOf DTO constraint).
  /// Nullable at the column level so email-only walk-in bookings are
  /// possible — DB no longer requires a phone for every row.
  customerPhone String?
  customerEmail String?

  adminNotes      String?   @db.Text
  confirmedAt     DateTime?
  confirmedById   String?
  rejectionReason String?
  cancelledAt     DateTime?
  cancelledBy     String?
  seatedAt        DateTime?
  completedAt     DateTime?

  tableId String?
  table   Table?  @relation("ReservationAssignedTable", fields: [tableId], references: [id], onDelete: SetNull)

  // Back-relation for Table.reservationHold (auto-RESERVED hold set by
  // the reservation-scheduler 30 min before this reservation starts).
  // Empty array unless the scheduler has currently holding a table for
  // this row — in practice 0 or 1 entries.
  heldTables Table[] @relation("TableReservationHold")

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, reservationNumber])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, status])
  @@index([tableId])
  // Overlap-check query: WHERE tenantId AND tableId AND date AND
  // startTime/endTime range. tableId+date+startTime covers it.
  @@index([tenantId, tableId, date, startTime])
  @@map("reservations")
}

// ========================================
// INTEGRATION SETTINGS
// ========================================

model IntegrationSettings {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Integration type
  integrationType String // PAYMENT_GATEWAY, POS_HARDWARE, THIRD_PARTY_API, DELIVERY_APP, ACCOUNTING, CRM, INVENTORY
  provider        String // stripe, paytr, pos_terminal, quickbooks, etc.
  name            String // User-friendly name

  // Configuration (stored as JSON)
  config Json // Flexible config object based on integration type

  // Status
  isEnabled    Boolean @default(false)
  isConfigured Boolean @default(false)

  // Metadata
  lastSyncedAt DateTime?
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, integrationType, provider])
  @@index([tenantId])
  @@index([integrationType])
  @@map("integration_settings")
}

model ApiKey {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // API Key details
  name      String // User-friendly name (e.g., "Production API", "Mobile App")
  // SHA-256 hash of the issued key. The plaintext is shown to the user once
  // at creation and never stored; lookup uses keyHash only.
  keyHash   String @unique
  keyPrefix String // First few characters for identification (e.g., "pk_live_...")

  // Permissions & Scopes
  scopes String[] // Array of permissions (e.g., ["orders:read", "orders:write", "menu:read"])

  // Webhook configuration
  webhookUrl    String?
  webhookEvents String[] @default([]) // Events to send to webhook (e.g., ["order.created", "order.updated"])

  // Status
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  // Usage tracking
  lastUsedAt DateTime?
  usageCount Int       @default(0)

  // Security
  ipWhitelist String[] @default([]) // Allowed IP addresses (empty = allow all)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([isActive])
  @@map("api_keys")
}

// ========================================
// CONTACT MESSAGES (Public)
// ========================================

model ContactMessage {
  id      String  @id @default(uuid())
  name    String
  email   String
  phone   String?
  message String  @db.Text

  // Status tracking
  status String @default("NEW") // NEW, READ, REPLIED, ARCHIVED

  // Admin notes
  adminNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ========================================
// CUSTOMER MANAGEMENT (CRM)
// ========================================

model Customer {
  id            String  @id @default(uuid())
  name          String
  email         String?
  phone         String?
  phoneVerified Boolean @default(false)

  // Loyalty & Engagement
  loyaltyPoints Int      @default(0)
  loyaltyTier   String   @default("BRONZE") // BRONZE, SILVER, GOLD, PLATINUM
  tags          String[] @default([]) // "VIP", "Regular", "New", etc.
  notes         String?  @db.Text

  // Referral System
  referralCode String? @unique // Unique code for this customer to share (optional)
  referredBy   String? // Referral code that was used to sign up

  // Statistics
  totalOrders  Int     @default(0)
  totalSpent   Decimal @default(0) @db.Decimal(10, 2)
  averageOrder Decimal @default(0) @db.Decimal(10, 2)

  // Birthday & Marketing
  birthday    DateTime?
  preferences Json? // Dietary preferences, favorite items, etc.

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  lastVisit DateTime?

  // Relations
  orders              Order[]              @relation("CustomerOrders")
  payments            Payment[]            @relation("CustomerPayments")
  sessions            CustomerSession[]
  loyaltyTransactions LoyaltyTransaction[]
  referralsMade       CustomerReferral[]   @relation("ReferralsMade")
  referralsReceived   CustomerReferral?    @relation("ReferralsReceived")

  @@unique([tenantId, email])
  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([email])
  @@index([phone])
  @@index([referralCode])
  @@index([loyaltyTier])
  @@map("customers")
}

// ========================================
// CUSTOMER SESSIONS & LOYALTY
// ========================================

model CustomerSession {
  id        String @id @default(uuid())
  sessionId String @unique // Public session identifier

  // Customer identification
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)

  // Session details
  tableId  String?
  phone    String? // Optional phone for identification
  isActive Boolean @default(true)

  // Session metadata
  userAgent String?
  ipAddress String?

  // Geolocation (for security validation)
  latitude  Float?
  longitude Float?

  // Expiration
  expiresAt    DateTime
  lastActivity DateTime @default(now())

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([customerId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("customer_sessions")
}

model LoyaltyTransaction {
  id String @id @default(uuid())

  // Tenant isolation is now explicit. onDelete: Restrict on the customer
  // relation means a customer with loyalty history can't be hard-deleted;
  // callers must soft-delete / anonymize + keep the audit trail. Matches
  // the typical fiscal/regulatory stance on loyalty liabilities.
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  // Transaction details
  type        String // EARNED, REDEEMED, EXPIRED, ADJUSTMENT, BONUS, REFERRAL
  points      Int // Positive for earned, negative for redeemed
  description String

  // Order reference (if applicable)
  orderId     String?
  orderNumber String?
  orderAmount Decimal? @db.Decimal(10, 2)

  // Referral tracking
  referredCustomerId String? // Customer who was referred (for referral bonuses)

  // Balance tracking
  balanceBefore Int // Points balance before transaction
  balanceAfter  Int // Points balance after transaction

  // Metadata
  metadata Json? // Additional data like promotion ID, birthday bonus, etc.

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([customerId])
  @@index([createdAt])
  @@index([type])
  @@map("loyalty_transactions")
}

model PhoneVerification {
  id        String   @id @default(uuid())
  phone     String
  code      String // 6-digit OTP code
  verified  Boolean  @default(false)
  expiresAt DateTime // OTP expires after 10 minutes

  // Session tracking
  sessionId String?
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Rate limiting
  attempts    Int @default(0)
  maxAttempts Int @default(3)

  createdAt  DateTime  @default(now())
  verifiedAt DateTime?

  @@index([phone, tenantId])
  @@index([code])
  @@index([expiresAt])
  @@map("phone_verifications")
}

model CustomerReferral {
  id String @id @default(uuid())

  // Referrer (person who shared the referral code)
  referrerId String
  referrer   Customer @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)

  // Referred (person who used the referral code)
  referredId String   @unique
  referred   Customer @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: Cascade)

  // Referral details
  referralCode String // Unique code used
  status       String @default("PENDING") // PENDING, COMPLETED, EXPIRED

  // Rewards
  referrerReward Int       @default(0) // Points given to referrer
  referredReward Int       @default(0) // Points given to referred customer
  rewardedAt     DateTime?

  createdAt   DateTime  @default(now())
  completedAt DateTime? // When referred customer completed qualifying action

  @@index([referrerId])
  @@index([referredId])
  @@index([referralCode])
  @@index([status])
  @@map("customer_referrals")
}

// ========================================
// NOTIFICATION SYSTEM
// ========================================

model Notification {
  id      String @id @default(uuid())
  title   String
  message String @db.Text
  type    String // INFO, WARNING, ERROR, SUCCESS, ORDER, STOCK, SYSTEM

  // Notification data (for deep links, actions, etc.)
  data Json?

  // Target
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Delivery
  isGlobal Boolean @default(false) // If true, sent to all users in tenant
  priority String  @default("NORMAL") // LOW, NORMAL, HIGH, URGENT

  createdAt DateTime  @default(now())
  expiresAt DateTime?

  // Relations
  readBy UserNotificationRead[]

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  // Hot query: WHERE tenantId AND (userId=? OR isGlobal=true) AND
  // (expiresAt IS NULL OR expiresAt > now()). Composite covers the
  // tenant scope + global vs targeted + expiry filter in one index.
  @@index([tenantId, isGlobal, expiresAt])
  @@map("notifications")
}

model UserNotificationRead {
  id String @id @default(uuid())

  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  readAt DateTime @default(now())

  @@unique([notificationId, userId])
  @@index([userId])
  @@index([notificationId])
  @@map("user_notification_reads")
}

// ========================================
// CUSTOMER REQUEST SYSTEM
// ========================================

model WaiterRequest {
  id        String  @id @default(uuid())
  message   String?
  status    String  @default("PENDING") // PENDING, ACKNOWLEDGED, COMPLETED
  sessionId String
  tenantId  String
  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?     @relation("AcknowledgedWaiterRequests", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tableId])
  @@index([status])
  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("waiter_requests")
}

model BillRequest {
  id        String @id @default(uuid())
  status    String @default("PENDING") // PENDING, ACKNOWLEDGED, COMPLETED
  sessionId String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  acknowledgedAt   DateTime?
  acknowledgedById String?
  acknowledgedBy   User?     @relation("AcknowledgedBillRequests", fields: [acknowledgedById], references: [id], onDelete: SetNull)

  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tableId])
  @@index([status])
  @@index([sessionId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("bill_requests")
}

// ========================================
// DESKTOP APPLICATION RELEASES
// ========================================

model DesktopRelease {
  id         String @id @default(uuid())
  version    String @unique // e.g., "0.2.6" (synced with web app)
  releaseTag String @unique // e.g., "v0.2.6"

  published Boolean  @default(false)
  pubDate   DateTime @default(now())

  // GitHub Release URLs for each platform
  windowsUrl        String?
  windowsSignature  String?
  macArmUrl         String?
  macArmSignature   String?
  macIntelUrl       String?
  macIntelSignature String?
  linuxUrl          String?
  linuxSignature    String?

  // Release metadata
  releaseNotes  String  @db.Text // Markdown formatted release notes
  changelog     String? @db.Text // Detailed changelog
  downloadCount Int     @default(0) // Total downloads across all platforms

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
  @@index([published, pubDate])
  @@map("desktop_releases")
}

// ========================================
// Z REPORT (END OF DAY) SYSTEM
// ========================================

model ZReport {
  id           String   @id @default(uuid())
  reportNumber String // Auto-generated report number (e.g., "Z-20250117-001")
  reportDate   DateTime // End of day date
  closingTime  DateTime @default(now())

  // Closing details
  closingType String @default("MANUAL") // MANUAL, AUTOMATIC

  // Staff who performed the closing
  closedById String
  closedBy   User   @relation(fields: [closedById], references: [id], onDelete: Restrict)

  // Branch/Terminal information (optional for multi-location)
  branchName String?
  terminalId String?

  // Sales Summary
  totalSales    Decimal @db.Decimal(10, 2)
  totalOrders   Int
  totalDiscount Decimal @default(0) @db.Decimal(10, 2)
  totalRefunds  Decimal @default(0) @db.Decimal(10, 2)
  netSales      Decimal @db.Decimal(10, 2) // totalSales - totalRefunds
  totalTax      Decimal @default(0) @db.Decimal(10, 2)
  taxBreakdown  Json?

  // Order Type Breakdown
  dineInSales    Decimal @default(0) @db.Decimal(10, 2)
  dineInOrders   Int     @default(0)
  takeawaySales  Decimal @default(0) @db.Decimal(10, 2)
  takeawayOrders Int     @default(0)
  deliverySales  Decimal @default(0) @db.Decimal(10, 2)
  deliveryOrders Int     @default(0)

  // Payment Method Summary
  cashPayments        Decimal @default(0) @db.Decimal(10, 2)
  cashPaymentCount    Int     @default(0)
  cardPayments        Decimal @default(0) @db.Decimal(10, 2)
  cardPaymentCount    Int     @default(0)
  digitalPayments     Decimal @default(0) @db.Decimal(10, 2)
  digitalPaymentCount Int     @default(0)

  // Cash Drawer Summary
  openingCash    Decimal @db.Decimal(10, 2)
  expectedCash   Decimal @db.Decimal(10, 2)
  countedCash    Decimal @db.Decimal(10, 2)
  cashDifference Decimal @db.Decimal(10, 2) // countedCash - expectedCash
  cashInOut      Decimal @default(0) @db.Decimal(10, 2) // Non-sales movements

  // Refunds & Cancellations
  cancelledOrders       Int     @default(0)
  cancelledOrdersAmount Decimal @default(0) @db.Decimal(10, 2)
  refundedPayments      Int     @default(0)
  refundedAmount        Decimal @default(0) @db.Decimal(10, 2)

  // Staff Performance (stored as JSON for flexibility)
  staffPerformance Json? // Array of {staffId, staffName, sales, orders, refunds}

  // Product Group Sales (stored as JSON)
  categoryBreakdown Json? // Array of {categoryId, categoryName, sales, quantity}

  // Top Products (stored as JSON)
  topProducts Json? // Array of {productId, productName, quantity, revenue}

  // System Status
  openChecks       Int     @default(0) // Should be 0 for successful closing
  openChecksAmount Decimal @default(0) @db.Decimal(10, 2)

  // Metadata
  notes           String? @db.Text
  systemGenerated Boolean @default(false)

  // Report export tracking
  pdfExported     Boolean   @default(false)
  pdfUrl          String?
  excelExported   Boolean   @default(false)
  excelUrl        String?
  emailSent       Boolean   @default(false)
  emailSentAt     DateTime?
  emailRecipients String[]  @default([]) // Who received the email
  emailError      String? // Last email error if any

  // Fiscal finalization — once set, totals are locked and every write path
  // asserts isFinalized=false. payloadHash is sha256 of the canonical
  // fiscal payload at finalization time so tampering is detectable on audit.
  isFinalized   Boolean   @default(false)
  finalizedAt   DateTime?
  finalizedById String?
  payloadHash   String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cashDrawerMovements CashDrawerMovement[]

  @@unique([tenantId, reportNumber])
  @@index([tenantId])
  @@index([reportDate])
  @@index([closedById])
  @@map("z_reports")
}

model CashDrawerMovement {
  id     String  @id @default(uuid())
  type   String // OPENING, CLOSING, CASH_IN, CASH_OUT, ADJUSTMENT
  amount Decimal @db.Decimal(10, 2)
  reason String?
  notes  String? @db.Text

  // Cash counting details (for CLOSING type)
  denominationBreakdown Json? // {100: 5, 50: 10, 20: 15, etc.}

  // Z Report reference (optional, null for daily movements)
  zReportId String?
  zReport   ZReport? @relation(fields: [zReportId], references: [id], onDelete: Cascade)

  // Staff who performed the movement
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([zReportId])
  @@index([userId])
  @@index([createdAt])
  @@map("cash_drawer_movements")
}

// ========================================
// PUBLIC STATISTICS & ANALYTICS
// ========================================

model PageView {
  id String @id @default(uuid())

  // Page tracking
  page     String // "landing", "pricing", "features", etc.
  path     String // Full URL path
  referrer String? // Where visitor came from

  // Geographic data (from IP geolocation)
  country     String?
  countryCode String?
  city        String?
  region      String?

  // Session info
  sessionId String? // Anonymous session tracking
  userAgent String?
  ipHash    String? // Hashed IP for privacy (don't store raw IP)

  // Device info
  deviceType String? // "desktop", "mobile", "tablet"
  browser    String?

  createdAt DateTime @default(now())

  @@index([page, createdAt])
  @@index([country])
  @@index([city])
  @@index([sessionId])
  @@map("page_views")
}

model PublicReview {
  id String @id @default(uuid())

  // Reviewer info
  name       String
  email      String
  restaurant String? // Restaurant name (optional)
  avatar     String? // Initials or image URL

  // Review content
  rating  Int // 1-5 stars
  comment String @db.Text

  // Moderation
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedAt DateTime?

  // Geographic context
  country String?
  city    String?

  // Verification
  isVerified Boolean @default(false) // Verified customer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([rating])
  @@map("public_reviews")
}

model PublicStatsCache {
  id String @id @default("main")

  // Cached statistics (updated periodically)
  totalViews     Int   @default(0)
  uniqueVisitors Int   @default(0)
  totalReviews   Int   @default(0)
  averageRating  Float @default(0)
  totalTenants   Int   @default(0) // Active restaurants

  // Business metrics for landing page
  totalOrders  Int   @default(0) // Total completed orders
  totalRevenue Float @default(0) // Total revenue in TRY

  // Geographic breakdown (JSON)
  countryDistribution Json? // {country: count}
  cityDistribution    Json? // {city: count}

  // Time-based stats
  viewsToday     Int @default(0)
  viewsThisWeek  Int @default(0)
  viewsThisMonth Int @default(0)

  lastUpdated DateTime @default(now())

  @@map("public_stats_cache")
}

// ========================================
// SUPER ADMIN MANAGEMENT
// ========================================

model SuperAdmin {
  id        String @id @default(uuid())
  email     String @unique
  password  String
  firstName String
  lastName  String
  status    String @default("ACTIVE") // ACTIVE, INACTIVE

  // 2FA (TOTP)
  twoFactorSecret        String?
  twoFactorEnabled       Boolean   @default(false)
  // Secret that has been generated but not yet confirmed by a successful
  // TOTP; promoted to twoFactorSecret only after enable2FA verifies it.
  pendingTwoFactorSecret String?
  // One-time recovery codes (sha256-hashed) for when the authenticator
  // is lost. Each entry gets removed as it is used.
  backupCodes            String[]  @default([])
  // Replay-protection: records the TOTP time step of the last accepted
  // code, plus when it expires. A code can only be used once.
  lastTotpStep           BigInt?
  lastTotpStepExpiresAt  DateTime?

  // Session revocation: bumped on logout, password change, 2FA change,
  // account suspension. Access tokens carry this version and are
  // rejected once they don't match.
  tokenVersion Int @default(0)

  lastLogin    DateTime?
  lastLoginIp  String?
  failedLogins Int       @default(0)
  lockedUntil  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("super_admins")
}

// ========================================
// AUDIT LOG SYSTEM
// ========================================

model AuditLog {
  id               String   @id @default(uuid())
  action           String // LOGIN, LOGOUT, VIEW, CREATE, UPDATE, DELETE, SUSPEND
  entityType       String // TENANT, USER, SUBSCRIPTION, PLAN
  entityId         String?
  actorId          String
  actorEmail       String
  previousData     Json?
  newData          Json?
  metadata         Json? // {ip, userAgent, requestId}
  targetTenantId   String?
  targetTenantName String?
  createdAt        DateTime @default(now())

  @@index([actorId])
  @@index([entityType])
  @@index([targetTenantId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ========================================
// USER ACTIVITY TRACKING
// ========================================

model UserActivity {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  action    String // LOGIN, LOGOUT, LOGIN_FAILED
  ip        String?
  userAgent String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([createdAt])
  @@map("user_activities")
}

// ========================================
// RESTAURANT ANALYTICS (AI-POWERED)
// ========================================

model Camera {
  id          String  @id @default(uuid())
  name        String
  description String?
  streamUrl   String // Encrypted RTSP/ONVIF URL
  streamType  String  @default("RTSP") // RTSP, ONVIF, HLS, WEBRTC

  // Floor plan calibration
  calibrationData Json? // {corners: [{imageX, imageY, floorX, floorZ}], homographyMatrix: [...]}

  rotationY Float? @default(0) // Horizontal rotation (degrees)
  fov       Float? @default(90) // Field of view (degrees)

  // Status and health
  status       String    @default("OFFLINE") // ONLINE, OFFLINE, ERROR, CALIBRATING
  lastSeenAt   DateTime?
  errorMessage String?

  // Edge device assignment
  edgeDeviceId String?
  edgeDevice   EdgeDevice? @relation(fields: [edgeDeviceId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([status])
  @@index([edgeDeviceId])
  @@map("cameras")
}

model OccupancyRecord {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())

  // Anonymous tracking ID (per session, not personally identifiable)
  trackingId String // e.g., "track_abc123" - assigned by edge device

  // Position in floor plan coordinates (meters from origin)
  positionX Float
  positionZ Float
  positionY Float @default(0) // Height estimation (0 = floor level)

  // Person state classification
  state String // STANDING, SITTING, MOVING, WAITING

  // Confidence score from ML model (0-1)
  confidence Float @default(0.9)

  // Optional table association
  tableId String?
  table   Table?  @relation(fields: [tableId], references: [id], onDelete: SetNull)

  // Source camera
  cameraId String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, timestamp])
  @@index([tableId])
  @@index([trackingId, timestamp])
  @@index([state])
  @@map("occupancy_records")
}

model TrafficFlowRecord {
  id         String   @id @default(uuid())
  hourBucket DateTime // Rounded to hour for aggregation

  // Grid cell coordinates (floor plan divided into cells)
  cellX    Int // Grid X coordinate
  cellZ    Int // Grid Z coordinate
  cellSize Float @default(1.0) // Cell size in meters

  // Traffic metrics
  personCount  Int // Number of unique persons passing through
  avgDwellTime Float? // Average time spent in cell (seconds)
  entrances    Int    @default(0) // People entering cell
  exits        Int    @default(0) // People exiting cell

  // Direction flow (JSON for flexibility)
  flowDirections Json? // {north: 10, south: 5, east: 3, west: 8}

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, hourBucket, cellX, cellZ])
  @@index([tenantId, hourBucket])
  @@index([cellX, cellZ])
  @@map("traffic_flow_records")
}

model TableAnalytics {
  id   String   @id @default(uuid())
  date DateTime @db.Date

  tableId String
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)

  // Occupancy metrics (in minutes)
  totalOccupiedMinutes Int @default(0)
  totalDiningMinutes   Int @default(0) // When orders are active
  totalIdleMinutes     Int @default(0) // Occupied but no orders
  totalEmptyMinutes    Int @default(0) // Table unoccupied

  // Session metrics
  totalSessions      Int    @default(0) // Number of table turns
  avgSessionDuration Float? // Average session length (minutes)
  avgDiningDuration  Float? // Average dining time (minutes)
  avgIdleDuration    Float? // Average idle time after dining (minutes)

  // Revenue metrics
  revenueGenerated Decimal  @default(0) @db.Decimal(10, 2)
  ordersCount      Int      @default(0)
  avgOrderValue    Decimal? @db.Decimal(10, 2)
  revenuePerMinute Decimal? @db.Decimal(10, 4) // Revenue efficiency

  // Utilization score (0-100)
  utilizationScore Float? // Calculated: (occupiedMinutes / operatingMinutes) * 100

  // Peak hours (JSON for flexibility)
  peakHours Json? // {hour: occupancyPercentage}

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tableId, date])
  @@index([tenantId, date])
  @@index([tableId])
  @@map("table_analytics")
}

model AnalyticsInsight {
  id String @id @default(uuid())

  // Insight classification
  type     String // SPACE_OPTIMIZATION, TRAFFIC_BOTTLENECK, TABLE_UNDERUTILIZATION,
  // CUSTOMER_BEHAVIOR, REVENUE_OPPORTUNITY, STAFFING_SUGGESTION
  category String @default("OPERATIONAL") // OPERATIONAL, REVENUE, CUSTOMER, LAYOUT
  severity String @default("INFO") // INFO, WARNING, CRITICAL

  // Content
  title          String // e.g., "Table 7 is underutilized"
  description    String @db.Text // Detailed explanation
  recommendation String @db.Text // Actionable suggestion

  // Affected entities
  affectedTableIds String[] @default([])
  affectedAreaData Json? // {x: number, z: number, width: number, depth: number}

  // Supporting data
  supportingData Json? // Charts, metrics, evidence

  // Impact estimation
  potentialImpact String? // "Could increase revenue by 15%"
  confidenceScore Float   @default(0.8) // ML confidence (0-1)

  // Status tracking
  status          String    @default("NEW") // NEW, REVIEWED, IN_PROGRESS, IMPLEMENTED, DISMISSED
  reviewedAt      DateTime?
  reviewedBy      String?
  implementedAt   DateTime?
  dismissedReason String?

  // Validity period
  validFrom  DateTime  @default(now())
  validUntil DateTime? // Insight may expire

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, createdAt])
  @@index([severity])
  @@map("analytics_insights")
}

model AnalyticsHeatmapCache {
  id String @id @default(uuid())

  // Time range
  startTime   DateTime
  endTime     DateTime
  granularity String // HOURLY, DAILY, WEEKLY

  // Grid configuration
  gridWidth Int // Number of cells in X direction
  gridDepth Int // Number of cells in Z direction
  cellSize  Float // Cell size in meters

  // Heatmap data (2D array as JSON)
  heatmapData Json // [[value, value, ...], [...], ...]
  maxValue    Float // For normalization
  minValue    Float

  // Metadata
  metric String // OCCUPANCY, DWELL_TIME, TRAFFIC, REVENUE

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  expiresAt DateTime // Cache expiration

  @@unique([tenantId, startTime, endTime, granularity, metric])
  @@index([tenantId, metric])
  @@index([expiresAt])
  @@map("analytics_heatmap_cache")
}

model EdgeDevice {
  id          String  @id @default(uuid())
  deviceId    String // Unique device identifier (e.g., "edge-001")
  name        String // Human-readable name
  description String?

  // Hardware info
  hardwareType    String? // "JETSON_ORIN", "RASPBERRY_PI_5", "CUSTOM"
  firmwareVersion String?
  ipAddress       String?
  macAddress      String?

  // Connection status
  status        String    @default("OFFLINE") // ONLINE, OFFLINE, ERROR, UPDATING
  lastHeartbeat DateTime?
  lastSeenAt    DateTime?
  errorMessage  String?

  // Capabilities
  capabilities Json? // {yolov8: true, pose: true, tracking: true, gpuAccel: true}

  // Configuration
  config Json? // Device-specific configuration

  // Assigned cameras
  cameras Camera[]

  // Health metrics
  cpuUsage    Float? // Last reported CPU usage (0-100)
  memoryUsage Float? // Last reported memory usage (0-100)
  gpuUsage    Float? // Last reported GPU usage (0-100)
  temperature Float? // Last reported temperature (Celsius)
  uptime      Int? // Uptime in seconds

  // Statistics
  framesProcessed BigInt @default(0)
  detectionsTotal BigInt @default(0)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, deviceId])
  @@index([tenantId])
  @@index([status])
  @@map("edge_devices")
}

// ========================================
// DELIVERY PLATFORM INTEGRATION
// ========================================

model DeliveryPlatformConfig {
  id String @id @default(uuid())

  platform  String // YEMEKSEPETI, GETIR, TRENDYOL, MIGROS
  isEnabled Boolean @default(false)

  // Authentication (all three fields hold AES-256-GCM-encrypted JSON;
  // see common/helpers/encryption.helper.ts). Never log these or return
  // them from tenant-facing endpoints.
  credentials    Json? // { ciphertext, iv, authTag } or null
  accessToken    String? // AES-GCM-encrypted bearer token
  tokenExpiresAt DateTime? // Token expiration time

  // Platform identifiers
  remoteRestaurantId String? // Platform's restaurant/vendor ID

  // Restaurant status on platform
  restaurantOpen Boolean @default(false)

  // Sync tracking
  lastOrderPollAt DateTime?
  lastMenuSyncAt  DateTime?

  // Circuit breaker / error tracking
  lastError   String?
  lastErrorAt DateTime?
  errorCount  Int       @default(0)

  // Configuration options
  autoAccept  Boolean @default(true) // Auto-accept incoming orders
  notifySound String? // Custom notification sound identifier

  // Soft delete marker so we don't orphan in-flight orders / mappings
  // when an admin hits Delete while orders are still syncing.
  deletedAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, platform])
  // Platform-wide uniqueness: two tenants can't claim the same remote
  // restaurant id (prior gap allowed disabled tenants to collide with
  // enabled ones and mis-route webhooks).
  @@unique([platform, remoteRestaurantId])
  @@index([tenantId])
  @@index([platform])
  @@index([isEnabled])
  @@map("delivery_platform_configs")
}

model DeliveryPlatformLog {
  id String @id @default(uuid())

  platform  String // YEMEKSEPETI, GETIR, TRENDYOL, MIGROS
  direction String // INBOUND, OUTBOUND
  action    String // e.g., ORDER_RECEIVED, ORDER_ACCEPTED, STATUS_UPDATE, AUTH_REFRESH

  // Related entities
  orderId    String? // Internal order ID (if applicable)
  externalId String? // Platform's order/entity ID

  // Request/response data
  request    Json?
  response   Json?
  statusCode Int?

  // Result
  success Boolean
  error   String?

  // Retry mechanism (dead letter queue)
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  nextRetryAt DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([platform])
  @@index([orderId])
  @@index([success])
  @@index([nextRetryAt])
  @@map("delivery_platform_logs")
}

model MenuItemMapping {
  id String @id @default(uuid())

  platform       String // YEMEKSEPETI, GETIR, TRENDYOL, MIGROS
  externalItemId String // Platform's product/item ID

  // Sync data
  externalData Json? // Platform-specific item metadata
  isActive     Boolean   @default(true)
  lastSyncedAt DateTime?

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, platform, externalItemId])
  @@index([tenantId])
  @@index([productId])
  @@index([platform])
  @@map("menu_item_mappings")
}

// ========================================
// INGREDIENT-LEVEL STOCK MANAGEMENT
// ========================================

model StockItemCategory {
  id          String  @id @default(uuid())
  name        String
  description String?
  color       String? // For UI badge color

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  stockItems StockItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("stock_item_categories")
}

model StockItem {
  id          String  @id @default(uuid())
  name        String
  sku         String?
  unit        String // KG, G, L, ML, PCS, BOX, BAG, CAN, BOTTLE, BUNCH, SLICE, PORTION
  description String?

  currentStock Decimal @default(0) @db.Decimal(10, 3)
  minStock     Decimal @default(0) @db.Decimal(10, 3)
  costPerUnit  Decimal @default(0) @db.Decimal(10, 4)

  trackExpiry Boolean @default(false)
  isActive    Boolean @default(true)

  categoryId String?
  category   StockItemCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  batches             StockBatch[]
  recipeIngredients   RecipeIngredient[]
  supplierStockItems  SupplierStockItem[]
  purchaseOrderItems  PurchaseOrderItem[]
  ingredientMovements IngredientMovement[]
  wasteLogs           WasteLog[]
  stockCountItems     StockCountItem[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([categoryId])
  @@index([isActive])
  @@map("stock_items")
}

model StockBatch {
  id          String  @id @default(uuid())
  batchNumber String?
  quantity    Decimal @db.Decimal(10, 3) // Remaining quantity in this batch
  costPerUnit Decimal @db.Decimal(10, 4)

  receivedAt DateTime  @default(now())
  expiryDate DateTime?

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  purchaseOrderItemId String?
  purchaseOrderItem   PurchaseOrderItem? @relation(fields: [purchaseOrderItemId], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([stockItemId])
  @@index([expiryDate])
  @@map("stock_batches")
}

model Recipe {
  id    String  @id @default(uuid())
  name  String?
  notes String?
  yield Int     @default(1) // How many portions this recipe makes

  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  ingredients RecipeIngredient[]

  @@index([tenantId])
  @@map("recipes")
}

model RecipeIngredient {
  id       String  @id @default(uuid())
  quantity Decimal @db.Decimal(10, 3)

  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([recipeId, stockItemId])
  @@index([recipeId])
  @@index([stockItemId])
  @@map("recipe_ingredients")
}

model Supplier {
  id           String  @id @default(uuid())
  name         String
  contactName  String?
  email        String?
  phone        String?
  address      String?
  paymentTerms String? // e.g., "Net 30", "COD"
  notes        String?
  isActive     Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  supplierStockItems SupplierStockItem[]
  purchaseOrders     PurchaseOrder[]

  @@index([tenantId])
  @@index([isActive])
  @@map("suppliers")
}

model SupplierStockItem {
  id          String  @id @default(uuid())
  supplierSku String?
  unitPrice   Decimal @db.Decimal(10, 4)
  isPreferred Boolean @default(false)

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([supplierId, stockItemId])
  @@index([supplierId])
  @@index([stockItemId])
  @@map("supplier_stock_items")
}

model PurchaseOrder {
  id           String    @id @default(uuid())
  orderNumber  String
  status       String    @default("DRAFT") // DRAFT, SUBMITTED, PARTIALLY_RECEIVED, RECEIVED, CANCELLED
  notes        String?
  expectedDate DateTime?
  createdById  String?

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  submittedAt DateTime?
  receivedAt  DateTime?

  // Relations
  items PurchaseOrderItem[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id               String  @id @default(uuid())
  quantityOrdered  Decimal @db.Decimal(10, 3)
  quantityReceived Decimal @default(0) @db.Decimal(10, 3)
  unitPrice        Decimal @db.Decimal(10, 4)

  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  // Relations
  batches StockBatch[]

  @@index([purchaseOrderId])
  @@index([stockItemId])
  @@map("purchase_order_items")
}

model IngredientMovement {
  id            String   @id @default(uuid())
  type          String // IN, OUT, ADJUSTMENT, WASTE, ORDER_DEDUCTION, ORDER_REVERSAL, PO_RECEIVE, PO_CANCEL_REVERSAL, COUNT_ADJUSTMENT
  quantity      Decimal  @db.Decimal(10, 3) // Positive for additions, negative for deductions
  costPerUnit   Decimal? @db.Decimal(10, 4)
  notes         String?
  referenceType String? // ORDER, PURCHASE_ORDER, WASTE_LOG, STOCK_COUNT
  referenceId   String?
  // Audit: who triggered the movement (null for system/scheduler paths).
  createdById   String?

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([stockItemId])
  @@index([type])
  @@index([referenceType, referenceId])
  @@index([createdAt])
  // Stock-history report (per-item): WHERE stockItemId AND createdAt BETWEEN ?.
  @@index([stockItemId, createdAt])
  // Per-tenant date-bounded queries (cost / waste / "last 30 days for
  // this tenant") — the dominant access pattern for cross-item reports.
  @@index([tenantId, createdAt])
  @@map("ingredient_movements")
}

model WasteLog {
  id          String   @id @default(uuid())
  quantity    Decimal  @db.Decimal(10, 3)
  reason      String // EXPIRED, SPOILED, DAMAGED, OVERPRODUCTION, PREPARATION_WASTE, CUSTOMER_RETURN, OTHER
  notes       String?
  cost        Decimal? @db.Decimal(10, 4) // Calculated cost of waste
  createdById String?

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([stockItemId])
  @@index([reason])
  @@index([createdAt])
  @@map("waste_logs")
}

model StockCount {
  id          String  @id @default(uuid())
  name        String?
  status      String  @default("IN_PROGRESS") // IN_PROGRESS, COMPLETED, CANCELLED
  notes       String?
  createdById String?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  // Relations
  items StockCountItem[]

  @@index([tenantId])
  @@index([status])
  @@map("stock_counts")
}

model StockCountItem {
  id          String   @id @default(uuid())
  expectedQty Decimal  @db.Decimal(10, 3) // Snapshot of currentStock at count start
  countedQty  Decimal? @db.Decimal(10, 3) // What was actually counted
  variance    Decimal? @db.Decimal(10, 3) // countedQty - expectedQty

  stockCountId String
  stockCount   StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)

  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)

  @@unique([stockCountId, stockItemId])
  @@index([stockCountId])
  @@index([stockItemId])
  @@map("stock_count_items")
}

model StockSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enableAutoDeduction Boolean @default(true)
  deductOnStatus      String  @default("PREPARING") // Which order status triggers deduction
  lowStockAlertDays   Int     @default(3) // Days before expiry to alert
  poNumberPrefix      String  @default("PO")
  // When false (default), deductions that would drop a stock item
  // below zero are refused. When true, negative stock is allowed and
  // the shortfall is recorded for investigation.
  allowNegativeStock  Boolean @default(false)
  // Monotonic per-tenant PO counter; used by purchase-orders.service
  // to mint collision-free order numbers in a transaction.
  poSequence          Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("stock_settings")
}

// ========================================
// PERSONNEL MANAGEMENT
// ========================================

model Attendance {
  id String @id @default(uuid())

  date     DateTime  @db.Date
  clockIn  DateTime
  clockOut DateTime?

  breakStart DateTime?
  breakEnd   DateTime?

  totalWorkedMinutes Int @default(0)
  totalBreakMinutes  Int @default(0)
  overtimeMinutes    Int @default(0)

  status      String  @default("CLOCKED_IN") // CLOCKED_IN, ON_BREAK, CLOCKED_OUT
  isLate      Boolean @default(false)
  lateMinutes Int     @default(0)
  notes       String?

  shiftAssignmentId String?
  shiftAssignment   ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id], onDelete: SetNull)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([userId])
  @@index([status])
  @@map("attendances")
}

model ShiftTemplate {
  id                 String  @id @default(uuid())
  name               String
  startTime          String // HH:mm format
  endTime            String // HH:mm format
  color              String  @default("#3B82F6") // Hex color
  gracePeriodMinutes Int     @default(15)
  isActive           Boolean @default(true)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  assignments ShiftAssignment[]

  @@index([tenantId])
  @@map("shift_templates")
}

model ShiftAssignment {
  id     String   @id @default(uuid())
  date   DateTime @db.Date
  status String   @default("SCHEDULED") // SCHEDULED, COMPLETED, MISSED, SWAPPED
  notes  String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shiftTemplateId String
  shiftTemplate   ShiftTemplate @relation(fields: [shiftTemplateId], references: [id], onDelete: Cascade)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attendances           Attendance[]
  swapRequestsRequester ShiftSwapRequest[] @relation("SwapRequester")
  swapRequestsTarget    ShiftSwapRequest[] @relation("SwapTarget")

  @@unique([userId, date])
  @@index([tenantId])
  @@index([tenantId, date])
  @@index([userId])
  @@index([shiftTemplateId])
  @@map("shift_assignments")
}

model ShiftSwapRequest {
  id     String  @id @default(uuid())
  status String  @default("PENDING") // PENDING, TARGET_ACCEPTED, TARGET_REJECTED, APPROVED, REJECTED
  reason String?

  // Two-stage approval: the target employee must consent before a
  // manager can apply the swap. Prior flow let a manager force a swap
  // onto an unwilling employee.
  targetRespondedAt DateTime?
  targetApproved    Boolean?

  requesterId String
  requester   User   @relation("SwapRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  targetId String
  target   User   @relation("SwapTarget", fields: [targetId], references: [id], onDelete: Cascade)

  requesterAssignmentId String
  requesterAssignment   ShiftAssignment @relation("SwapRequester", fields: [requesterAssignmentId], references: [id], onDelete: Cascade)

  targetAssignmentId String
  targetAssignment   ShiftAssignment @relation("SwapTarget", fields: [targetAssignmentId], references: [id], onDelete: Cascade)

  approvedById String?
  approvedBy   User?   @relation("SwapApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([requesterId])
  @@index([targetId])
  @@index([status])
  @@map("shift_swap_requests")
}

// ========================================
// MARKETING / SALES REPRESENTATIVE PANEL
// ========================================

model MarketingUser {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  firstName    String
  lastName     String
  phone        String?
  avatar       String?
  role         String // SALES_MANAGER, SALES_REP
  status       String    @default("ACTIVE") // ACTIVE, INACTIVE
  lastLogin    DateTime?
  lastLoginIp  String?
  failedLogins Int       @default(0)
  lockedUntil  DateTime?

  // Public-facing referral code (e.g. "AHMET42"). Marketers share it
  // via /?ref=CODE links or word-of-mouth; the checkout flow resolves
  // it back to this row, auto-creates a WON Lead on payment success,
  // and lifetime SIGNUP/RENEWAL/UPSELL commissions accrue to this user.
  // Nullable so legacy rows backfill cleanly; @unique to keep the
  // resolver O(1).
  referralCode          String?   @unique
  referralCodeUpdatedAt DateTime?

  // Session revocation token: carried in access/refresh JWTs; bumped on
  // logout and on password change so outstanding tokens are invalidated.
  tokenVersion Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  leads            Lead[]                  @relation("AssignedRep")
  activities       LeadActivity[]
  tasks            MarketingTask[]
  offers           LeadOffer[]
  commissions      Commission[]
  notifications    MarketingNotification[]
  referredPayments SubscriptionPayment[]   @relation("ReferredByMarketer")

  @@index([email])
  @@index([role])
  @@index([status])
  @@map("marketing_users")
}

model Lead {
  id            String    @id @default(uuid())
  businessName  String
  contactPerson String
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  city          String?
  region        String?
  businessType  String // CAFE, RESTAURANT, BAR, PATISSERIE, FAST_FOOD, OTHER
  tableCount    Int?
  branchCount   Int?
  currentSystem String?
  source        String // INSTAGRAM, REFERRAL, FIELD_VISIT, ADS, WEBSITE, PHONE, OTHER
  status        String    @default("NEW") // NEW, CONTACTED, NOT_REACHABLE, MEETING_DONE, DEMO_SCHEDULED, OFFER_SENT, WAITING, WON, LOST
  lostReason    String?
  notes         String?   @db.Text
  nextFollowUp  DateTime?
  priority      String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  externalRef   String?   @unique

  // Assigned sales rep
  assignedToId String?
  assignedTo   MarketingUser? @relation("AssignedRep", fields: [assignedToId], references: [id], onDelete: SetNull)

  // Conversion tracking
  convertedTenantId String?   @unique
  convertedTenant   Tenant?   @relation("ConvertedTenant", fields: [convertedTenantId], references: [id], onDelete: SetNull)
  convertedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  activities  LeadActivity[]
  tasks       MarketingTask[]
  offers      LeadOffer[]
  commissions Commission[]    @relation("CommissionLead")

  @@index([assignedToId])
  @@index([status])
  @@index([city])
  @@index([source])
  @@index([businessType])
  @@index([createdAt])
  @@index([nextFollowUp])
  @@index([priority])
  @@index([assignedToId, status])
  @@index([status, createdAt])
  @@map("leads")
}

model LeadActivity {
  id          String  @id @default(uuid())
  type        String // CALL, VISIT, NOTE, EMAIL, WHATSAPP, STATUS_CHANGE, DEMO, MEETING
  title       String
  description String? @db.Text
  outcome     String? // POSITIVE, NEGATIVE, NEUTRAL, NO_ANSWER
  duration    Int? // Duration in minutes (for calls/visits)
  /// Structured payload for typed activity kinds. Currently used for
  /// assignment events ({ kind: 'assignment', fromUserId, fromUserName,
  /// toUserId, toUserName, bulk?, auto? }) so the timeline can render
  /// "Ahmet → Mehmet" without re-parsing the title string. Nullable so
  /// every legacy STATUS_CHANGE row stays valid without a backfill.
  metadata    Json?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   MarketingUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([createdById])
  @@index([createdAt])
  @@index([type])
  @@map("lead_activities")
}

model MarketingTask {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        String // CALL, VISIT, DEMO, FOLLOW_UP, MEETING, OTHER
  status      String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  priority    String    @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  dueDate     DateTime
  completedAt DateTime?

  leadId String?
  lead   Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  assignedToId String
  assignedTo   MarketingUser @relation(fields: [assignedToId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([assignedToId])
  @@index([leadId])
  @@index([dueDate])
  @@index([status])
  @@index([assignedToId, status])
  @@index([dueDate, status])
  @@map("marketing_tasks")
}

model LeadOffer {
  id          String            @id @default(uuid())
  planId      String?
  plan        SubscriptionPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)
  customPrice Decimal?          @db.Decimal(10, 2)
  discount    Decimal?          @db.Decimal(5, 2)
  trialDays   Int?
  notes       String?           @db.Text
  status      String            @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  validUntil  DateTime?
  sentAt      DateTime?
  respondedAt DateTime?

  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   MarketingUser @relation(fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([createdById])
  @@index([status])
  @@index([leadId, status])
  @@map("lead_offers")
}

model Commission {
  id       String  @id @default(uuid())
  amount   Decimal @db.Decimal(10, 2)
  type     String // SIGNUP, RENEWAL, UPSELL
  status   String  @default("PENDING") // PENDING, APPROVED, PAID
  period   String // "2026-04" (YYYY-MM format)
  tenantId String?
  tenant   Tenant? @relation("MarketingCommissions", fields: [tenantId], references: [id], onDelete: SetNull)
  leadId   String?
  lead     Lead?   @relation("CommissionLead", fields: [leadId], references: [id], onDelete: SetNull)
  notes    String? @db.Text

  marketingUserId String
  marketingUser   MarketingUser @relation(fields: [marketingUserId], references: [id], onDelete: Restrict)

  approvedAt   DateTime?
  approvedById String? // MarketingUser.id of the manager who approved
  paidAt       DateTime?
  paidById     String? // MarketingUser.id of the manager who marked paid
  /// Append-only state-transition log: every approve/pay/amount edit
  /// pushes one entry `{ at, actorId, action, prev?, next? }`. JSON
  /// rather than a separate table because the volume is low (a few
  /// rows per commission lifetime) and we never need to join on it.
  auditLog     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([marketingUserId])
  @@index([tenantId])
  @@index([leadId])
  @@index([period])
  @@index([status])
  @@index([period, status])
  @@map("commissions")
}

model MarketingNotification {
  id       String  @id @default(uuid())
  type     String // FOLLOW_UP_REMINDER, DEMO_REMINDER, INACTIVE_LEAD, OFFER_EXPIRING, TASK_DUE
  title    String
  message  String
  isRead   Boolean @default(false)
  metadata Json?

  userId String
  user   MarketingUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("marketing_notifications")
}

/// Singleton row controlling how newly-created leads are auto-assigned
/// to sales reps. A NULL row (or strategy=DISABLED) means manual
/// assignment only — managers dispatch leads themselves. ROUND_ROBIN
/// rotates through ACTIVE SALES_REP users in stable createdAt order,
/// using `lastAssignedToId` as a cursor. LEAST_LOADED picks the rep
/// with the fewest open (non-WON/LOST) leads at the time of the new
/// lead. Only one row is expected; seeded with strategy=DISABLED.
model MarketingDistributionConfig {
  id               String   @id @default(uuid())
  strategy         String   @default("DISABLED") // DISABLED, ROUND_ROBIN, LEAST_LOADED
  lastAssignedToId String?
  updatedById      String?
  updatedAt        DateTime @updatedAt

  @@map("marketing_distribution_config")
}

// ========================================
// ACCOUNTING SETTINGS
// ========================================

model AccountingSettings {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  autoGenerateInvoice Boolean @default(false)

  companyName      String?
  companyTaxId     String?
  companyTaxOffice String?
  companyAddress   String?
  companyPhone     String?
  companyEmail     String?

  provider String  @default("NONE")
  autoSync Boolean @default(false)

  parasutCompanyId    String?
  parasutClientId     String?
  parasutClientSecret String?
  parasutUsername     String?
  parasutPassword     String?

  logoApiUrl     String?
  logoUsername   String?
  logoPassword   String?
  logoFirmNumber String?

  foribaApiUrl      String?
  foribaUsername    String?
  foribaPassword    String?
  foribaServiceType String?

  invoicePrefix          String @default("FTR")
  nextInvoiceNumber      Int    @default(1)
  defaultPaymentTermDays Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@map("accounting_settings")
}

// ========================================
// SALES INVOICE (Müşteri Satış Faturası)
// ========================================

model SalesInvoice {
  id            String @id @default(uuid())
  invoiceNumber String
  type          String @default("SALES")
  status        String @default("DRAFT")

  customerName      String?
  customerPhone     String?
  customerEmail     String?
  customerTaxId     String?
  customerTaxOffice String?

  subtotal    Decimal @db.Decimal(10, 2)
  taxAmount   Decimal @db.Decimal(10, 2)
  totalAmount Decimal @db.Decimal(10, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  currency    String  @default("TRY")

  taxBreakdown Json?

  orderId       String?
  order         Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  // When the invoice corresponds to a single Payment row (progressive
  // / per-customer flow), paymentId links to it so each customer can
  // get their own KDV breakdown. Order-level invoices (single payment
  // closing the whole bill, or splitBill) leave paymentId null. The
  // partial unique constraint (one invoice per payment) is enforced
  // by a unique index defined in the migration; Prisma's @unique on
  // a nullable column would block multiple NULLs in Postgres.
  paymentId     String?
  payment       Payment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  paymentMethod String?

  externalId       String?
  externalProvider String?
  externalStatus   String?
  syncedAt         DateTime?
  syncError        String?

  pdfUrl String?

  issueDate DateTime  @default(now())
  dueDate   DateTime?

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items SalesInvoiceItem[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([orderId])
  @@index([paymentId])
  @@index([status])
  @@index([issueDate])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id          String  @id @default(uuid())
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  taxRate     Int     @default(10)
  taxAmount   Decimal @db.Decimal(10, 2)
  subtotal    Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  invoiceId String
  invoice   SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("sales_invoice_items")
}

// ========================================
// LEGAL DOCUMENTS & CONSENTS
// ========================================
//
// Versioned legal documents (KVKK, Mesafeli Satış, İade Politikası, etc.)
// and per-user consent records. Two-table design:
//
//   LegalDocument — content + version. New version = new row, old row
//     keeps `isCurrent: false` so existing Consent FKs stay valid.
//   Consent — immutable acceptance record. One row per (user, version).
//     Required at checkout for create-intent to succeed.
//
// `kind` is a string (not a Prisma enum) following the project-wide
// convention of String + comment listing allowed values.
//   KVKK              — 6698 sayılı KVKK aydınlatma metni
//   DISTANCE_SALES    — 6502 sayılı Tüketici Kanunu mesafeli satış
//   REFUND_POLICY     — 14 günlük cayma hakkı + iade politikası
//   TERMS_OF_SERVICE  — genel kullanım koşulları (mevcut /terms sayfası)
//   PRIVACY_POLICY    — gizlilik politikası (mevcut /privacy sayfası)

model LegalDocument {
  id           String   @id @default(uuid())
  kind         String // KVKK, DISTANCE_SALES, REFUND_POLICY, TERMS_OF_SERVICE, PRIVACY_POLICY
  version      String // "1.0", "1.1", "2.0" — semver-ish, set when publishing
  locale       String // "tr" canonical for TR launch; future-proofed for "en", "ar", ...
  title        String
  bodyMarkdown String   @db.Text
  effectiveAt  DateTime
  // One row per kind has isCurrent=true. When publishing a new version,
  // LegalDocumentsService flips the prior row's isCurrent to false in
  // the same transaction. Old rows are NEVER deleted because existing
  // Consent rows reference them by id (audit-proof).
  isCurrent    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  consents Consent[]

  @@unique([kind, version, locale])
  @@index([kind, isCurrent])
  @@map("legal_documents")
}

model Consent {
  id              String        @id @default(uuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentId      String
  document        LegalDocument @relation(fields: [documentId], references: [id])
  // Denormalised snapshot — lets reports filter "users who accepted KVKK"
  // without joining LegalDocument every time.
  documentKind    String
  documentVersion String
  ipAddress       String?
  userAgent       String?
  // Which checkout (if any) triggered the consent. Null when the user
  // accepts an updated version outside a checkout flow (re-acceptance).
  subscriptionId  String?
  acceptedAt      DateTime      @default(now())

  @@index([userId, documentKind])
  @@index([subscriptionId])
  @@index([documentId])
  @@map("consents")
}

// ========================================
// ENTITLEMENTS + OUTBOX (HummyTummy Phase 1)
// ========================================
//
// The Entitlement Engine answers "what can this tenant do *right now*". It is
// the single source of truth for feature gating — separate from how features
// were *bought* (Subscription/SubscriptionPlan/featureOverrides). Every grant
// is a row sourced from a plan, an add-on, an admin override, or a grace
// window. The fold rules are:
//   feature.*        boolean   OR    (any source granting -> enabled)
//   limit.*          number    SUM   (plan base + addon increments)
//   integration.*    string[]  UNION
// `source` is the precise origin (e.g. "plan:PRO", "addon:kds-extra-station:abc",
// "override:admin:user_42", "grace:past-due"). Revoking a source removes only
// the rows tagged with that source — no other rows are touched. `value` is
// JSONB to allow future shapes (per-branch limits, structured config).
//
// The OutboxEvent table buffers domain events for durable, at-least-once
// delivery. Producers write event rows inside the same transaction that
// mutates business state; the worker drains them onto the in-process bus
// (EventEmitter2). Consumers MUST be idempotent on `id` (UUIDv7 = sortable).
// This unblocks every cross-module path (entitlement recompute on subscription
// change, fulfilment on payment, KDS routing on order, etc.) without forcing
// a message broker yet.

model FeatureEntitlement {
  id         String    @id @default(uuid())
  tenantId   String
  // v2.8.92: explicit Tenant FK + cascade. Deletes from the tenant table
  // now sweep the engine projection along with them, and writes against a
  // bogus tenantId fail loudly at the DB instead of sitting around as
  // orphan rows.
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Scope: `tenant` (default), `branch` (future once branches are extracted),
  // `device` (future device-level licensing). Stored as plain string to stay
  // consistent with the project's "String + comment" enum convention.
  scope      String    @default("tenant")
  branchId   String?
  // Dotted key, e.g. "feature.kds", "limit.maxTables", "integration.delivery".
  key        String
  // JSONB value: boolean for feature.*, number for limit.*, string[] for
  // integration.*, free-form for forward compatibility.
  value      Json
  // Precise origin so revocation can target exactly one row.
  // Examples: "plan:PRO", "addon:kds-extra-station:7f...", "override:admin",
  // "grace:past-due".
  source     String
  // Optional expiry — used by grace windows and time-boxed trials.
  validUntil DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // One (tenant, branch, key, source) tuple at a time. Reprojecting a source
  // upserts in place, so the table stays the size of "current state" not
  // "every change ever made" (the audit log carries the history).
  @@unique([tenantId, branchId, key, source])
  @@index([tenantId, key])
  @@index([tenantId, scope])
  @@index([validUntil])
  @@map("feature_entitlements")
}

model OutboxEvent {
  // UUIDv7 generated at the application layer so events sort by creation time
  // without needing a sequence; safe across replicas.
  id             String    @id
  // Versioned dotted name, e.g. "subscription.activated.v1", "order.created.v1".
  type           String
  tenantId       String?
  // The full event body. Consumers parse this with Zod against the event
  // contract in packages/event-contracts.
  payload        Json
  // Idempotency key emitted by the producer (often the same as id, but kept
  // separate so the same logical event can be re-emitted with a fresh id if
  // ever needed). Consumers dedupe on this.
  idempotencyKey String
  // Drain state machine: queued -> dispatching -> dispatched | failed.
  status         String    @default("queued")
  attempts       Int       @default(0)
  lastError      String?
  // Time the worker first dispatched the event to the bus. Used to compute
  // delivery lag p95 in observability.
  dispatchedAt   DateTime?
  // Earliest moment the worker should attempt redelivery after a failure.
  // Exponential backoff lives in OutboxWorkerService.
  nextAttemptAt  DateTime?
  createdAt      DateTime  @default(now())

  // Worker scans `status='queued' AND nextAttemptAt <= now()` in id order.
  @@index([status, nextAttemptAt])
  @@index([type, createdAt])
  @@index([tenantId, createdAt])
  @@map("outbox_events")
}

// ========================================
// MARKETPLACE: PLANS + ADD-ONS (HummyTummy Phase 2)
// ========================================
//
// SubscriptionPlan stays as the existing 4-tier plan model. The marketplace
// adds an orthogonal AddOn catalog: discrete units of capability that
// extend a tenant's entitlements without changing their plan. Add-ons are
// data-driven — super-admin can ship a new add-on by inserting a row.
//
// `grants` JSONB encodes the entitlement delta the add-on grants. Shape:
//   {
//     "feature.foo":            true,
//     "limit.kdsScreens":       1,
//     "integration.delivery":   ["yemeksepeti","getir"]
//   }
// The projector multiplies numeric grants by the tenant's `quantity` so the
// same add-on row supports `qty=3 extra KDS screens` without inflating the
// catalog. `deps` lists other add-on codes or `plan:<NAME>` prefixes that
// must already be present before purchase is allowed.

model MarketplaceAddOn {
  id          String   @id @default(uuid())
  // Stable code used by checkout/UI/dependencies. NEVER reuse a retired code.
  code        String   @unique
  name        String
  description String?
  // Coarse buckets for filtering in the marketplace UI:
  //   software     — extra modules (advanced reports, multi-branch)
  //   integration  — provider grants (fiscal-hugin, delivery-yemeksepeti)
  //   capacity     — numeric add-ons (extra-kds-screen, extra-tablet)
  //   support      — service tiers (priority support, on-site install)
  kind        String
  // Recurring add-ons charge each subscription cycle; one-time add-ons fire
  // once at purchase (typical for setup/install fees).
  billing     String   @default("recurring") // recurring|oneTime
  priceCents  Int
  currency    String   @default("TRY")
  // Entitlement delta — see header comment.
  grants      Json
  // Other add-on codes (or plan:<NAME>) required before purchase.
  deps        String[] @default([])
  // Lifecycle: draft can be edited freely; published is offered for sale;
  // archived stays in the catalog for already-active tenants but is hidden
  // from the marketplace.
  status      String   @default("draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenantAddOns TenantAddOn[]

  @@index([status, kind])
  @@map("marketplace_addons")
}

model TenantAddOn {
  id                  String   @id @default(uuid())
  tenantId            String
  addOnId             String
  addOn               MarketplaceAddOn @relation(fields: [addOnId], references: [id], onDelete: Restrict)
  // Optional branch scope. Null means tenant-wide; once branches land in
  // Phase 3 the marketplace UI will require a branch for capacity add-ons.
  branchId            String?
  // Multiplies numeric grants (capacity add-ons buy in quantity).
  quantity            Int      @default(1)
  // active during the period; cancelled stays visible until cancelAtPeriodEnd
  // hits the next billing tick; expired = ended billing period, no entitlement.
  status              String   @default("active")
  // Billing cycle bookkeeping. One-time add-ons set start = end = activatedAt.
  activatedAt         DateTime @default(now())
  currentPeriodStart  DateTime?
  currentPeriodEnd    DateTime?
  cancelAtPeriodEnd   Boolean  @default(false)
  cancelledAt         DateTime?
  endedAt             DateTime?
  // Link to the invoice/payment row that paid for this. Nullable for free
  // add-ons (promo grants, admin-issued comps).
  paymentRef          String?

  @@index([tenantId, status])
  @@index([addOnId])
  @@index([tenantId, branchId])
  @@map("tenant_addons")
}

// ========================================
// BRANCHES + DEVICE MESH (HummyTummy Phase 3)
// ========================================
//
// Branch is the per-location seam. Existing tenants are migrated with one
// "Main" branch, and the application keeps using "tenant-wide" for queries
// until features explicitly opt into branch-scoping. This is the first big
// step toward multi-branch chains.
//
// The Device Mesh treats every restaurant peripheral (tablet, KDS screen,
// printer, yazarkasa, POS terminal, caller box, local bridge) uniformly:
// a Device row + a capability list. The application never branches on
// vendor brand — capability presence is what routes commands.

model Branch {
  id          String   @id @default(uuid())
  tenantId    String
  // v2.8.93 — explicit Tenant FK + cascade. Pre-fix tenantId was a
  // free-form String column with no FK, so deleting a tenant left
  // orphan branches and a typo at write-time silently succeeded.
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   @default("Main")
  // Free-form code so chains can label as "IST-01", "ANK-Mall", etc.
  code        String?
  timezone    String   @default("UTC")
  // Address stored as JSON to avoid premature normalization (single,
  // double, embedded formats vary by country).
  address     Json?
  status      String   @default("active") // active|suspended|archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  devices     Device[]
  bridges     LocalBridgeAgent[]
  orders      Order[]
  tables      Table[]

  @@unique([tenantId, code])
  @@index([tenantId, status])
  @@map("branches")
}

// Polymorphic device registry — `kind` distinguishes the surface, but the
// routing layer dispatches on the union of `capabilities`. Adding a new
// hardware class is a config change, not a code change.
model Device {
  id              String   @id @default(uuid())
  tenantId        String
  // v2.8.93 — explicit Tenant FK + cascade. Matches the Branch fix
  // above; pre-fix a device's tenantId column had no DB-level integrity
  // check and orphan devices outlived their tenants.
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Optional until the device is assigned to a branch via pairing. Nullable
  // also covers a chain admin creating slots ahead of branch deployment.
  branchId        String?
  branch          Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  // tablet_waiter | tablet_customer | kds_screen | bar_screen | pos_terminal
  // yazarkasa | receipt_printer | kitchen_printer | caller_id | scanner | local_bridge
  kind            String
  // Capability tags — e.g. ['print_80mm', 'cash_drawer'] or ['display_kitchen'].
  // Free-form strings so a new firmware/feature can surface immediately.
  capabilities    String[] @default([])
  // online|offline|busy|error|maintenance|retired
  status          String   @default("unprovisioned")
  // Wall-clock last successful heartbeat. Null while unprovisioned.
  lastSeenAt      DateTime?
  serial          String?
  model           String?
  // sold (HummyTummy fulfilled), rented, byo (customer brought their own).
  ownership       String   @default("byo")
  warrantyUntil   DateTime?
  // When this device lives behind a bridge, the bridgeId is its parent.
  // Cloud-direct devices (tablets, KDS screens) have null bridgeId.
  bridgeId        String?
  bridge          LocalBridgeAgent? @relation(fields: [bridgeId], references: [id], onDelete: SetNull)
  // Pairing one-time-use bits. pairCode is what the user types; claimToken is
  // a single-use token returned by the API to bootstrap auth.
  pairCode        String?  @unique
  pairCodeExpiresAt DateTime?
  // Rotating bearer token (sha256 hashed) issued post-pair. Refreshed via
  // /devices/:id/token/refresh. Never store the raw token at rest.
  tokenHash       String?
  tokenExpiresAt  DateTime?
  // Free-form provisioning config — e.g. printer width, kitchen station id.
  config          Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  commands        DeviceCommand[]
  logs            DeviceLog[]

  @@unique([tenantId, serial])
  @@index([tenantId, branchId, kind])
  @@index([tenantId, status])
  @@index([bridgeId])
  @@map("devices")
}

// Outbound commands to a device. Per-device FIFO with priority. Workers ack
// by transitioning queued → done|failed with a result/error.
model DeviceCommand {
  id              String   @id @default(uuid())
  tenantId        String
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  // print_receipt | fiscal_receipt | charge_card | show_order | open_drawer | reboot ...
  kind            String
  payload         Json
  // Higher = pulled first by the device.
  priority        Int      @default(0)
  status          String   @default("queued") // queued|inflight|done|failed|expired
  attempts        Int      @default(0)
  expiresAt       DateTime?
  // Client-side idempotency key (UUIDv7 from producer). Unique per device
  // so retried sends don't duplicate.
  idempotencyKey  String
  result          Json?
  error           String?
  ackedAt         DateTime?
  createdAt       DateTime @default(now())
  // Tracks the last transition. The sweeper uses this (not createdAt) to
  // detect "inflight for too long": a command created an hour ago but
  // claimed seconds ago must NOT be swept as stuck.
  updatedAt       DateTime @updatedAt

  @@unique([deviceId, idempotencyKey])
  @@index([deviceId, status, priority(sort: Desc), createdAt])
  @@index([tenantId, status])
  @@index([status, updatedAt])
  @@map("device_commands")
}

model DeviceLog {
  id          String   @id @default(uuid())
  tenantId    String
  deviceId    String
  device      Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  // info|warn|error|metric — keeps the table dense.
  level       String
  category    String   // 'heartbeat'|'command'|'capability'|'lifecycle'
  message     String
  payload     Json?
  createdAt   DateTime @default(now())

  @@index([deviceId, createdAt(sort: Desc)])
  @@index([tenantId, level, createdAt])
  @@map("device_logs")
}

// Local Bridge Agent registry. One row per agent install (one per branch is
// typical, but multiple are supported for redundancy or per-station bridges).
model LocalBridgeAgent {
  id              String   @id @default(uuid())
  tenantId        String
  branchId        String
  branch          Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  // Provisioning token: a one-time-use string embedded at manufacture or
  // generated when the bridge is associated with a branch via admin UI.
  // Hashed at rest (sha256); never raw.
  provisioningTokenHash String?
  // Rotating bearer token (sha256 hashed) post-claim.
  tokenHash       String?
  tokenExpiresAt  DateTime?
  hostname        String?
  os              String?
  agentVersion    String?
  // online|offline|claiming|retired
  status          String   @default("claiming")
  lastSeenAt      DateTime?
  provisionedAt   DateTime?
  // SKU code if this bridge came from the HummyTummy hardware store.
  productSku      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  devices         Device[]

  // Provisioning tokens are single-use across the entire fleet — making
  // the hash globally unique means a race between two concurrent claim
  // requests (same token, same millisecond) fails the second one with a
  // unique-violation rather than handing out two valid bearer tokens.
  // Nullable column needs a partial index so the constraint only applies
  // to rows that still have a claim outstanding (cleared post-claim).
  @@unique([provisioningTokenHash])
  @@index([tenantId, branchId, status])
  @@map("local_bridge_agents")
}

// ========================================
// HARDWARE CATALOG + ORDERS (HummyTummy Phase 5)
// ========================================
//
// HardwareProduct is the SKU master. HardwareInventory tracks stock + serial
// allocations. HardwareOrder + HardwareOrderItem model the cart→order→ship
// flow. Shipment carries carrier-side state. InstallationRequest and Warranty
// hang off completed orders.

model HardwareProduct {
  id              String   @id @default(uuid())
  sku             String   @unique
  // tablet|kds_screen|pos_terminal|printer|yazarkasa|bridge|scanner|caller_id|cash_drawer|other|service
  // 'service' is v2.8.87 — extends the model to carry installation/integration
  // service offerings (one-time labour). Service rows ignore rentalMonthlyCents,
  // serials, warrantyMonths; their meaning lives in `serviceMeta`.
  category        String
  name            String
  brand           String?
  model           String?
  description     String?  @db.Text
  // Free-form specs: dimensions, ports, OS, etc.
  // Convention since v2.8.87: include `headlineSpecs: string[]` (max 3) for
  // the chip row on the storefront card. Storefront card reads
  // specs.headlineSpecs; falls back to nothing if absent.
  specs           Json?
  // Compat: { capabilities: ["print_80mm"], requiredPlan: ["PRO"], requiredAddOn: ["fiscal_hugin"] }
  compat          Json?
  // v2.8.87 — structured rich detail used by the product/service detail page.
  // Shape: { includes: string[], requirements: string[], faq: {q,a}[],
  //         steps: {title,body}[], videoUrl?, gallery?: string[] }
  // Per-locale variants supported via { tr: {...}, en: {...} } — the client
  // selects current locale, falls back to `tr`. Empty/null is fine: the
  // detail page degrades to spec-only.
  details         Json?
  // v2.8.87 — service-only metadata. Shape:
  //   { durationHours?: number, geoCoverage?: string[],
  //     requiresBranch?: boolean, serviceType: 'onsite'|'remote'|'consultation' }
  // CheckoutService reads serviceType to decide whether to mint an
  // InstallationRequest at provision-time (`onsite` only).
  serviceMeta     Json?
  priceCents      Int
  // For rental SKUs (e.g. HummyBox-Lite); null for sale-only.
  rentalMonthlyCents Int?
  currency        String   @default("TRY")
  warrantyMonths  Int      @default(12)
  images          String[] @default([])
  // in_stock|preorder|out_of_stock|discontinued
  stockStatus     String   @default("in_stock")
  // shippingProfile = { weightKg, dimsCm, carrier?, leadTimeDays }
  shippingProfile Json?
  // Lifecycle inside the catalog: published rows are sold in the public store;
  // draft is admin-only; archived hides from the store but keeps history.
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  inventory       HardwareInventory[]
  orderItems      HardwareOrderItem[]

  @@index([category, status])
  @@map("hardware_products")
}

// Per-SKU stock counts and serial allocations. Single-warehouse for MVP;
// adding `warehouseId` later is trivial.
model HardwareInventory {
  id          String   @id @default(uuid())
  productId   String
  product     HardwareProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  // available + allocated + shipped = lifetime received. The triple is kept
  // explicit so finance/ops queries don't need joins to derive flow stats.
  available   Int      @default(0)
  allocated   Int      @default(0)
  shipped     Int      @default(0)
  // Free serials pool (FIFO). When an order line allocates units, the first
  // N serials are popped and assigned to HardwareOrderItem.serials.
  serialsAvailable String[] @default([])
  updatedAt   DateTime @updatedAt

  @@unique([productId])
  @@map("hardware_inventory")
}

model HardwareOrder {
  id              String   @id @default(uuid())
  tenantId        String
  // Optional branch the buyer wants the hardware shipped to / installed at.
  branchId        String?
  // draft (cart) → pending_payment → paid → fulfillment → shipped →
  // delivered → installed → completed.  Cancellation states: cancelled,
  // refunded. Status transitions are append-only — a returned order keeps
  // the shipped → delivered → returned history.
  status          String   @default("draft")
  subtotalCents   Int      @default(0)
  taxCents        Int      @default(0)
  shippingCents   Int      @default(0)
  totalCents      Int      @default(0)
  currency        String   @default("TRY")
  shippingAddress Json?
  billingAddress  Json?
  // installation: null | requested | scheduled | done | declined
  installation    String?
  paymentRef      String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           HardwareOrderItem[]
  shipments       Shipment[]
  installations   InstallationRequest[]

  @@index([tenantId, status])
  @@index([createdAt])
  @@map("hardware_orders")
}

/// v2.8.85 — Mixed-cart checkout intents.
///
/// A CheckoutIntent row is the seam between the synchronous "create PayTR
/// token" call and the asynchronous webhook callback. The frontend posts a
/// cart, we mint a stable paymentRef (prefix "CK-"), persist the cart shape
/// + amount under that ref, and hand PayTR the iframe token. When PayTR
/// calls back hours later we look the cart up by ref and run the same
/// CheckoutService.confirmAndProvision path that admin-comp uses.
///
/// Why persist the cart server-side instead of round-tripping it through
/// the client: a malicious buyer could otherwise swap the cart between
/// get-token and webhook callback (e.g. price a single license then
/// provision a full hardware order). Server-stored cart + paymentRef makes
/// the buyer's input authoritative at one moment only — at /intent time.
///
/// Status lifecycle:
///   pending     — token issued, no PayTR callback yet
///   succeeded   — PayTR callback verified status=success, not yet provisioned
///   provisioned — CheckoutService.confirmAndProvision completed
///   failed      — PayTR callback verified status=failed (failureReason set)
model CheckoutIntent {
  id              String   @id @default(uuid())
  tenantId        String
  paymentRef      String   @unique
  cartJson        Json
  amountCents     Int
  currency        String   @default("TRY")
  providerId      String   @default("paytr")
  status          String   @default("pending")
  failureReason   String?
  hardwareOrderId String?
  addOnIds        String[] @default([])
  createdAt       DateTime @default(now())
  succeededAt     DateTime?
  provisionedAt   DateTime?
  failedAt        DateTime?

  @@index([tenantId, status])
  @@index([createdAt])
  @@map("checkout_intents")
}

model HardwareOrderItem {
  id          String   @id @default(uuid())
  orderId     String
  order       HardwareOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     HardwareProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  sku         String   // snapshot at purchase time
  name        String   // snapshot
  qty         Int
  unitCents   Int
  // Serials allocated to this line item, in order of allocation.
  serials     String[] @default([])
  // rent | sell — determines whether the resulting Device row is `rented`
  // or `sold` for warranty/billing purposes.
  acquisition String   @default("sell")

  @@index([orderId])
  @@map("hardware_order_items")
}

model Shipment {
  id          String   @id @default(uuid())
  orderId     String
  order       HardwareOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  carrier     String   // 'manual'|'yurtici'|'aras'|'mng'|... — adapter id
  trackingNo  String?
  // pending|in_transit|out_for_delivery|delivered|returned|lost
  status      String   @default("pending")
  shippedAt   DateTime?
  deliveredAt DateTime?
  // Free-form payload for carrier-specific metadata (label url, etc.)
  meta        Json?

  @@index([orderId])
  @@index([carrier, status])
  @@map("shipments")
}

model InstallationRequest {
  id              String   @id @default(uuid())
  tenantId        String
  branchId        String?
  hwOrderId       String?
  hwOrder         HardwareOrder? @relation(fields: [hwOrderId], references: [id], onDelete: SetNull)
  // requested|scheduled|in_progress|done|cancelled|no_show
  status          String   @default("requested")
  scheduledFor    DateTime?
  assignedTo      String?  // SuperAdmin id (technician) — optional
  // Operator-supplied preferences from the request form.
  preferredDates  DateTime[] @default([])
  notes           String?  @db.Text
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, status])
  @@index([scheduledFor])
  @@map("installation_requests")
}

model Warranty {
  id          String   @id @default(uuid())
  tenantId    String
  // Device row this warranty covers (nullable until device is paired).
  deviceId    String?
  productId   String
  serial      String
  startAt     DateTime
  endAt       DateTime
  // Each claim is { date, issue, status, resolution? } appended into JSON
  // for now; promote to its own table once volume warrants.
  claims      Json[]   @default([])
  status      String   @default("active") // active|expired|claimed|voided
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, serial])
  @@index([tenantId, status])
  @@index([endAt])
  @@map("warranties")
}

// ========================================
// FISCAL DEVICES + RECEIPTS (HummyTummy Phase 7)
// ========================================
//
// Models stay vendor-agnostic. Brand-specific behavior lives in a separate
// adapter module that implements the FiscalProvider interface.

model FiscalDeviceRecord {
  id            String   @id @default(uuid())
  tenantId      String
  branchId      String?
  // 'efatura' (cloud, no hardware), 'hugin', 'beko', 'profilo', 'mock'
  providerId    String
  // Optional link to the Device mesh row when this fiscal device is a
  // physical yazarkasa wired through a bridge.
  deviceId      String?
  serial        String
  model         String?
  // Free-form capability tags: 'receipt', 'invoice', 'cancel', 'z_report'
  capabilities  String[] @default([])
  // online|offline|error|maintenance|retired
  status        String   @default("offline")
  lastSeenAt    DateTime?
  // Provider-specific config (API keys, station code, VAT group map).
  config        Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipts      FiscalReceipt[]

  @@unique([tenantId, providerId, serial])
  @@index([tenantId, branchId, status])
  @@map("fiscal_devices")
}

model FiscalReceipt {
  id              String   @id @default(uuid())
  tenantId        String
  // Order this receipt is for. Nullable so admin-driven manual receipts can
  // be issued (rare; supported for parity with the legacy flow).
  orderId         String?
  fiscalDeviceId  String
  fiscalDevice    FiscalDeviceRecord @relation(fields: [fiscalDeviceId], references: [id], onDelete: Restrict)
  providerId      String
  // The fiscal_no / Z-no the device emits — populated after the device acks.
  fiscalNo        String?
  fiscalZNo       String?
  issuedAt        DateTime?
  totalCents      Int
  currency        String   @default("TRY")
  vatBreakdown    Json     // { "20": 4000, "10": 500, "1": 0 }
  // queued|inflight|issued|failed|cancelled
  status          String   @default("queued")
  // Per-call idempotency — survives retries from the outbox / device queue.
  idempotencyKey  String
  attempts        Int      @default(0)
  lastError       String?
  // Append-only line items for audit.
  lines           FiscalReceiptItem[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, idempotencyKey])
  @@index([orderId])
  @@index([fiscalDeviceId, issuedAt])
  @@map("fiscal_receipts")
}

model FiscalReceiptItem {
  id             String   @id @default(uuid())
  fiscalReceiptId String
  fiscalReceipt  FiscalReceipt @relation(fields: [fiscalReceiptId], references: [id], onDelete: Cascade)
  lineNo         Int
  productCode    String
  name           String
  qty            Decimal  @db.Decimal(10, 3)
  unitPriceCents Int
  vatRate        Int
  // Yazarkasa department code in TR (A..F). Optional for non-TR providers.
  vatGroup       String?
  discountCents  Int      @default(0)

  @@index([fiscalReceiptId, lineNo])
  @@map("fiscal_receipt_items")
}

model FiscalDayClose {
  id            String   @id @default(uuid())
  tenantId      String
  fiscalDeviceId String
  zNo           String?
  openedAt      DateTime?
  closedAt      DateTime?
  totals        Json     // { 'card': 12345, 'cash': 6789, 'vat_20': 1500 }

  @@index([tenantId, closedAt])
  @@map("fiscal_day_closes")
}

// ========================================
// CALLER / PHONE ORDERS (HummyTummy Phase 9)
// ========================================

model CallerEvent {
  id          String   @id @default(uuid())
  tenantId    String
  branchId    String?
  // 'twilio', 'verimor', 'analog-caller-id-box', ...
  providerId  String
  callId      String   // provider-side call id
  // 'incoming'|'answered'|'ended'|'missed'
  kind        String
  // E.164 if available; raw display otherwise.
  e164        String?
  // Optional matched customer (filled by the lookup pass after creation).
  customerId  String?
  agentUserId String?
  durationMs  Int?
  // Provider-specific extras (trunk id, recording url, etc.).
  meta        Json?
  // Order created from this call, when applicable.
  orderId     String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  @@index([tenantId, occurredAt(sort: Desc)])
  @@index([tenantId, e164])
  @@index([callId])
  @@map("caller_events")
}

// ========================================
// INTEGRATION GATEWAY (HummyTummy Phase 11)
// ========================================

model IntegrationProviderDef {
  // 'yemeksepeti', 'getir', 'iyzico', 'stripe', 'efatura', 'verimor', ...
  id          String  @id
  // 'delivery'|'payment'|'fiscal'|'voip'|'accounting'|'sms'|'whatsapp'
  kind        String
  name        String
  description String?
  // JSON Schema of the credentials the adapter needs. Rendered by the
  // admin UI; values stored in IntegrationConnection.credentialsEnc.
  configSchema Json
  // Whether HummyTummy provides this adapter officially or it's a partner
  // contribution (community).
  isOfficial  Boolean @default(true)
  status      String  @default("published")  // published|deprecated
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  connections IntegrationConnection[]

  @@index([kind, status])
  @@map("integration_providers")
}

model IntegrationConnection {
  id              String   @id @default(uuid())
  tenantId        String
  branchId        String?
  providerId      String
  provider        IntegrationProviderDef @relation(fields: [providerId], references: [id], onDelete: Restrict)
  // 'connected'|'error'|'pending'|'disconnected'
  status          String   @default("pending")
  // Envelope-encrypted credentials JSON. Storage layer applies AES-256-GCM
  // with a tenant-scoped key derived from KMS. Until KMS lands the bytea is
  // encrypted with a process-wide key from env — never raw secrets.
  credentialsEnc  Bytes?
  // Non-secret provider-specific config (store id, channel, etc.).
  config          Json?
  lastEventAt     DateTime?
  lastError       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  webhookEvents   IntegrationWebhookEvent[]

  @@index([tenantId, providerId])
  @@index([status])
  @@map("integration_connections")
}

model IntegrationWebhookEvent {
  id              String   @id @default(uuid())
  tenantId        String?
  connectionId    String?
  connection      IntegrationConnection? @relation(fields: [connectionId], references: [id], onDelete: SetNull)
  providerId      String
  // Provider-emitted event type, e.g. 'order.created', 'payment.succeeded'.
  type            String
  // Truncated signature for audit; raw never stored.
  signature       String?
  // Raw payload — kept for forensic replay. Auto-purged after 90d by the
  // existing audit retention job once that runs.
  payload         Json
  receivedAt      DateTime @default(now())
  processedAt     DateTime?
  result          String?
  attempts        Int      @default(0)
  lastError       String?

  @@index([connectionId, receivedAt])
  @@index([providerId, receivedAt])
  @@index([tenantId, providerId, signature])
  @@map("integration_webhook_events")
}

// ========================================
// OUTBOUND WEBHOOKS (tenant subscribers)
// ========================================

model TenantWebhookSubscription {
  id                  String   @id @default(uuid())
  tenantId            String
  url                 String
  // Event types the tenant wants to receive. "*" subscribes to everything.
  events              String[] @default([])
  // sha256 of the shared secret. Used as a fast-lookup fingerprint and
  // for backward-compatible verify-on-disk; the raw secret needed for the
  // outbound HMAC signature lives in `secretEnc` below, encrypted via KMS.
  secretHash          String
  // KMS-encrypted raw secret. The worker decrypts on each delivery and
  // signs the body so receivers can verify with their copy of the raw
  // secret. Encrypted with context { tenantId, purpose:'webhook_secret' }
  // so a leaked blob from tenant A is unusable for tenant B.
  secretEnc           Bytes?
  // active|paused. Auto-paused after `consecutiveFailures` >= 20 so a dead
  // endpoint doesn't drain the worker.
  status              String   @default("active")
  lastDeliveryAt      DateTime?
  lastDeliveryCode    Int?
  consecutiveFailures Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  deliveries          WebhookDelivery[]

  @@index([tenantId, status])
  @@map("tenant_webhook_subscriptions")
}

model WebhookDelivery {
  id                  String   @id @default(uuid())
  subscriptionId      String
  subscription        TenantWebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType           String
  eventId             String              // outbox event id (UUIDv7)
  url                 String
  status              String   @default("pending") // pending|delivered|failed
  attempts            Int      @default(0)
  lastStatusCode      Int?
  lastResponseSnippet String?
  nextAttemptAt       DateTime?
  deliveredAt         DateTime?
  createdAt           DateTime @default(now())

  @@unique([subscriptionId, eventId])
  @@index([status, nextAttemptAt])
  @@index([subscriptionId, createdAt])
  @@map("webhook_deliveries")
}
