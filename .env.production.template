# Production Environment Configuration Template
# Copy this to .env.production on your server and fill in the values

NODE_ENV=production

# Database Configuration
POSTGRES_DB=restaurant_pos_prod
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DATABASE_URL=postgresql://postgres:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/restaurant_pos_prod

# Redis Configuration
REDIS_URL=redis://redis:6379/2

# Server Configuration
PORT=3000
FRONTEND_PORT=80

# JWT Configuration - CHANGE THESE TO RANDOM SECURE VALUES
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_THIS_TO_DIFFERENT_RANDOM_SECRET_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=https://yourdomain.com

# Stripe Configuration (Production Mode)
STRIPE_SECRET_KEY=sk_live_your_production_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key
STRIPE_WEBHOOK_SECRET=whsec_your_production_webhook_secret

# Email Configuration (Production)
EMAIL_HOST=smtp.your-email-provider.com
EMAIL_PORT=587
EMAIL_SECURE=true
EMAIL_USER=your_email@domain.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@yourdomain.com

# Subscription Settings
DEFAULT_TRIAL_DAYS=14
TRIAL_REMINDER_DAYS=3

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Observability / metrics
# REQUIRED in production: bearer token for GET /api/metrics (Prometheus).
# Without it the metrics registry — payment/subscription/fiscal volumes,
# login-failure counts, outbox/DLQ depth, per-route latency — is readable by
# anyone who can reach the route. Boot aborts in prod if unset. 16+ chars.
METRICS_TOKEN=CHANGE_THIS_TO_RANDOM_TOKEN_32_CHARS

# Runtime DB statement timeout (ms), applied to the APP's connections only —
# migrations and pg_dump go through their own sessions and are unaffected.
# 0 disables. Default 60000.
DB_STATEMENT_TIMEOUT_MS=60000

# Container memory caps (compose mem_limit) + Node heap. Defaults suit a
# single mid-size VPS; size to the actual host. Keep --max-old-space-size
# comfortably under BACKEND_MEM_LIMIT so V8 GCs before Docker OOM-kills it.
# BACKEND_MEM_LIMIT=1536m
# BACKEND_NODE_OPTIONS=--max-old-space-size=1024
# POSTGRES_MEM_LIMIT=1g
# REDIS_MEM_LIMIT=512m
# REDIS_MAXMEMORY=384mb

# Database backups (scripts/backup-database.sh + ops/backup/ systemd timer).
# Backups MUST live outside the repo tree and be copied off-site.
# KDS_BACKUP_DIR=/var/lib/kds-deploy/backups/database
# Off-site target — pick ONE; REQUIRED for real disaster recovery:
# KDS_BACKUP_RCLONE_REMOTE=b2:kds-backups/prod
# KDS_BACKUP_S3_BUCKET=my-bucket/kds/prod

# Frontend Environment Variables
VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=wss://api.yourdomain.com
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
