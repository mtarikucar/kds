yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Misc
.cache/
temp/
tmp/

# Git worktrees (for parallel feature work)
.worktrees/
worktrees/

# Rust/Tauri
frontend/src-tauri/target/
**/target/
**/*.rs.bk
Cargo.lock



examples/
nul

# Playwright artifacts
playwright-report/
playwright-results.xml
test-results/

# Deploy script ephemera. The unified deploy.sh keeps real state under
# /var/lib/kds-deploy (outside the repo). These files are legacy
# outputs from the old deploy-production.sh and rendered env files
# from CI — if they end up in the working tree they'll block `git
# reset --hard` on the deploy box.
.last-deployment-images
.env.production.rendered
.env.test.rendered
